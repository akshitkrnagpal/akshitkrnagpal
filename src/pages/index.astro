---
import Layout from '../layouts/Layout.astro';
import Linkedin from '../components/simple-icons/linkedin.astro'
import Github from '../components/simple-icons/github.astro'
import X from '../components/simple-icons/x.astro'
---

<Layout>
  <main class="min-h-dvh relative overflow-hidden">
    <!-- Animated gradient background -->
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute top-[-20%] right-[-10%] w-[60vw] h-[60vw] max-w-[800px] max-h-[800px] rounded-full opacity-[0.07] blur-3xl animate-float" style="background: radial-gradient(circle, var(--color-accent) 0%, transparent 70%);"></div>
      <div class="absolute bottom-[-10%] left-[-5%] w-[40vw] h-[40vw] max-w-[500px] max-h-[500px] rounded-full opacity-[0.04] blur-3xl animate-float-delayed" style="background: radial-gradient(circle, #4a90d9 0%, transparent 70%);"></div>
    </div>

    <!-- Content -->
    <div class="relative z-10 min-h-dvh flex flex-col">
      <!-- Navigation -->
      <nav class="w-full px-6 md:px-12 lg:px-20 py-6 flex justify-between items-center animate-fade-in">
        <span class="text-sm tracking-widest uppercase font-medium" style="color: var(--color-muted);">Portfolio</span>
        <div class="flex items-center gap-2">
          <a
            href="/projects"
            class="text-sm tracking-wide font-medium px-4 py-2 border border-[var(--color-ink)]/10 transition-all duration-300 hover:border-[var(--color-ink)]/30 hover:bg-[var(--color-ink)]/[0.03]"
            style="color: var(--color-ink);"
          >
            Projects
          </a>
          <a
            href="/blog"
            class="text-sm tracking-wide font-medium px-4 py-2 border border-[var(--color-ink)]/10 transition-all duration-300 hover:border-[var(--color-ink)]/30 hover:bg-[var(--color-ink)]/[0.03]"
            style="color: var(--color-ink);"
          >
            Blog
          </a>
        </div>
      </nav>

      <!-- Hero -->
      <div class="flex-1 flex items-center justify-center px-6 md:px-12 lg:px-20 py-12">
        <div class="w-full max-w-6xl">

          <!-- Top section: Photo + Name -->
          <div class="flex flex-col items-center text-center mb-16">
            <!-- Photo with ring -->
            <div class="relative mb-8 animate-scale-in delay-1">
              <div class="absolute -inset-2 rounded-full border border-[var(--color-accent)]/20"></div>
              <div class="absolute -inset-5 rounded-full border border-[var(--color-ink)]/5"></div>
              <div class="w-32 h-32 md:w-40 md:h-40 rounded-full overflow-hidden ring-4 ring-[var(--color-paper)] shadow-xl">
                <img
                  src="https://avatars.githubusercontent.com/u/15872348"
                  alt="Akshit Kr Nagpal"
                  class="w-full h-full object-cover grayscale-[30%] hover:grayscale-0 transition-all duration-700"
                />
              </div>
              <!-- Status dot -->
              <div class="absolute bottom-2 right-2 w-4 h-4 rounded-full bg-emerald-500 ring-3 ring-[var(--color-paper)]"></div>
            </div>

            <!-- Name -->
            <h1 class="text-5xl md:text-6xl lg:text-7xl mb-3 leading-[1.05] animate-fade-up delay-2" style="font-family: var(--font-display);">
              Akshit Kr Nagpal
            </h1>

            <!-- Title with accent -->
            <div class="flex items-center gap-3 mb-6 animate-fade-up delay-3">
              <div class="w-8 h-px bg-[var(--color-accent)]"></div>
              <p class="text-sm md:text-base tracking-[0.2em] uppercase font-medium" style="color: var(--color-accent);">
                Software Engineer
              </p>
              <div class="w-8 h-px bg-[var(--color-accent)]"></div>
            </div>

            <!-- Bio -->
            <p class="text-lg md:text-xl leading-relaxed max-w-lg mx-auto mb-10 animate-fade-up delay-4" style="color: var(--color-muted);">
              Indie hacker and full-stack engineer. I build developer tools, ship side projects, and care deeply about clean code and great UX.
            </p>

            <!-- Social Links -->
            <div class="flex gap-5 animate-fade-up delay-5">
              <a
                href="https://github.com/akshitkrnagpal"
                target="_blank"
                rel="noopener noreferrer"
                aria-label="GitHub"
                class="transition-opacity duration-300 hover:opacity-60"
                style="color: var(--color-muted);"
              >
                <Github class="w-5 h-5" />
              </a>
              <a
                href="https://linkedin.com/in/akshitkrnagpal"
                target="_blank"
                rel="noopener noreferrer"
                aria-label="LinkedIn"
                class="transition-opacity duration-300 hover:opacity-60"
                style="color: var(--color-muted);"
              >
                <Linkedin class="w-5 h-5" />
              </a>
              <a
                href="https://x.com/akshit_io"
                target="_blank"
                rel="noopener noreferrer"
                aria-label="X (Twitter)"
                class="transition-opacity duration-300 hover:opacity-60"
                style="color: var(--color-muted);"
              >
                <X class="w-5 h-5" />
              </a>
            </div>
          </div>

        </div>
      </div>

      <!-- Footer accent line -->
      <div class="w-full h-1 bg-gradient-to-r from-transparent via-[var(--color-accent)] to-transparent animate-fade-in delay-6"></div>
    </div>
  </main>
</Layout>

<style>
  @keyframes float {
    0%, 100% { transform: translate(0, 0); }
    50% { transform: translate(-20px, 20px); }
  }

  @keyframes float-delayed {
    0%, 100% { transform: translate(0, 0); }
    50% { transform: translate(15px, -15px); }
  }

  .animate-float {
    animation: float 12s ease-in-out infinite;
  }

  .animate-float-delayed {
    animation: float-delayed 15s ease-in-out infinite;
  }
</style>
