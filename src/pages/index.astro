---
import Layout from "../layouts/Layout.astro";
import SiteFooter from "../components/SiteFooter.astro";
import SiteHeader from "../components/SiteHeader.astro";
import Github from "../components/simple-icons/github.astro";
import Linkedin from "../components/simple-icons/linkedin.astro";
import X from "../components/simple-icons/x.astro";
---

<Layout>
  <div class="site-shell">
    <SiteHeader current="home" />

    <main id="main-content">
      <section class="home-hero" aria-labelledby="page-title">
        <div class="home-hero__statement">
          <p class="kicker reveal">Portfolio / Software engineering</p>

          <h1 class="display-name reveal reveal--2" id="page-title">
            <span>Akshit Kr</span>
            <span>Nagpal</span>
          </h1>

          <div class="hero-deck reveal reveal--3">
            <p class="hero-deck__role">Software Engineer</p>
            <p class="hero-deck__bio">
              Indie hacker and full-stack engineer. I build developer tools, ship side projects, and care deeply about clean code and great UX.
            </p>
          </div>
        </div>

        <aside class="home-hero__profile reveal reveal--3" aria-label="Profile and social links">
          <div>
            <figure class="portrait-frame">
              <img
                src="https://avatars.githubusercontent.com/u/15872348"
                alt="Akshit Kr Nagpal"
                width="460"
                height="575"
                fetchpriority="high"
              />
            </figure>
            <div class="portrait-caption" aria-hidden="true">
              <span>Portrait</span>
              <span>01 / 01</span>
            </div>
          </div>

          <div class="social-index" aria-label="Social profiles">
            <a href="https://github.com/akshitkrnagpal" target="_blank" rel="noopener noreferrer">
              <Github /> GitHub <span>Profile</span>
            </a>
            <a href="https://linkedin.com/in/akshitkrnagpal" target="_blank" rel="noopener noreferrer">
              <Linkedin /> LinkedIn <span>Connect</span>
            </a>
            <a href="https://x.com/akshit_io" target="_blank" rel="noopener noreferrer">
              <X /> X <span>Follow</span>
            </a>
          </div>
        </aside>
      </section>

      <a class="home-project-link" href="/projects" aria-label="Explore selected projects">
        <div>
          <p class="home-project-link__label">Selected work / 09 projects</p>
          <h2>Products built with intent.</h2>
        </div>
        <span class="home-project-link__arrow" aria-hidden="true">↗</span>
      </a>
    </main>

    <SiteFooter />
  </div>
</Layout>
