---
import Layout from "../layouts/Layout.astro";
import Linkedin from "../components/simple-icons/linkedin.astro";
import Github from "../components/simple-icons/github.astro";
import X from "../components/simple-icons/x.astro";
---

<Layout>
  <div class="shell">
    <header class="site-header">
      <a class="site-id" href="/" aria-label="Akshit Kr Nagpal, home">
        akshit.io <span>/ portfolio</span>
      </a>
      <nav class="site-nav" aria-label="Primary navigation">
        <a href="/" aria-current="page">Index</a>
        <a href="/projects">Projects</a>
      </nav>
    </header>

    <div class="status-strip" aria-label="Page status">
      <span>route <strong>/index</strong></span>
      <span>render <strong>static</strong></span>
      <span>mode <strong>independent</strong></span>
      <span class="ok">● system online</span>
    </div>

    <main id="main-content" class="home-main">
      <section class="home-grid" aria-labelledby="intro-title">
        <div class="intro-block reveal">
          <p class="section-kicker">Identity / 001</p>
          <h1 id="intro-title">
            <span>Akshit Kr</span>
            Nagpal
          </h1>
          <p class="role-line"><span>const role =</span> “Software Engineer”;</p>
          <p class="intro-copy">
            Indie hacker and full-stack engineer. I build developer tools, ship side projects, and care deeply about clean code and great UX.
          </p>
          <div class="intro-actions">
            <a class="action-link primary internal" href="/projects">Inspect projects</a>
            <a class="action-link" href="https://github.com/akshitkrnagpal" target="_blank" rel="noopener noreferrer">
              GitHub
              <span class="sr-only"> (opens in a new tab)</span>
            </a>
          </div>
        </div>

        <aside class="identity-panel panel reveal reveal-delay-1" aria-label="Profile summary">
          <div class="panel-heading">
            <span>profile.sys</span>
          </div>
          <div class="portrait-wrap">
            <div class="portrait-rulers" aria-hidden="true">
              <span>00</span><span>16</span><span>32</span><span>48</span>
            </div>
            <div class="portrait-frame">
              <img
                src="https://avatars.githubusercontent.com/u/15872348"
                alt="Akshit Kr Nagpal"
                width="320"
                height="320"
                decoding="async"
              />
              <span class="portrait-corner corner-a" aria-hidden="true"></span>
              <span class="portrait-corner corner-b" aria-hidden="true"></span>
            </div>
          </div>
          <dl class="identity-data">
            <div>
              <dt>ID</dt>
              <dd>AKSHIT.KR.NAGPAL</dd>
            </div>
            <div>
              <dt>ROLE</dt>
              <dd>SOFTWARE ENGINEER</dd>
            </div>
            <div>
              <dt>MODE</dt>
              <dd>INDIE HACKER / FULL-STACK</dd>
            </div>
          </dl>
        </aside>
      </section>

      <section class="signal-grid reveal reveal-delay-2" aria-labelledby="signals-title">
        <div class="signal-intro">
          <p class="section-kicker">Operating signals / 002</p>
          <h2 id="signals-title">Build discipline</h2>
        </div>
        <ul class="signal-list" role="list">
          <li><span>01</span><strong>Developer tools</strong><small>Products for builders</small></li>
          <li><span>02</span><strong>Side projects</strong><small>Ideas shipped to production</small></li>
          <li><span>03</span><strong>Clean code</strong><small>Systems made maintainable</small></li>
          <li><span>04</span><strong>Great UX</strong><small>Details that remove friction</small></li>
        </ul>
      </section>

      <section class="contact-grid reveal reveal-delay-3" aria-labelledby="contact-title">
        <div>
          <p class="section-kicker">External links / 003</p>
          <h2 id="contact-title">Connect</h2>
        </div>
        <div class="social-links">
          <a href="https://github.com/akshitkrnagpal" target="_blank" rel="noopener noreferrer">
            <Github class="social-icon" fill="currentColor" aria-hidden="true" />
            <span><strong>GitHub</strong><small>@akshitkrnagpal</small></span>
            <i aria-hidden="true">↗</i>
            <span class="sr-only"> (opens in a new tab)</span>
          </a>
          <a href="https://linkedin.com/in/akshitkrnagpal" target="_blank" rel="noopener noreferrer">
            <Linkedin class="social-icon" fill="currentColor" aria-hidden="true" />
            <span><strong>LinkedIn</strong><small>/in/akshitkrnagpal</small></span>
            <i aria-hidden="true">↗</i>
            <span class="sr-only"> (opens in a new tab)</span>
          </a>
          <a href="https://x.com/akshit_io" target="_blank" rel="noopener noreferrer">
            <X class="social-icon" fill="currentColor" aria-hidden="true" />
            <span><strong>X</strong><small>@akshit_io</small></span>
            <i aria-hidden="true">↗</i>
            <span class="sr-only"> (opens in a new tab)</span>
          </a>
        </div>
      </section>
    </main>

    <footer class="site-footer">
      <span>akshit.io <strong>— software engineer</strong></span>
      <span>EOF / INDEX</span>
    </footer>
  </div>
</Layout>

<style>
  .home-main {
    padding: clamp(1rem, 3vw, 2.5rem);
  }

  .home-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.45fr) minmax(20rem, 0.72fr);
    min-height: min(45rem, calc(100dvh - 13rem));
    border: 1px solid var(--line);
  }

  .intro-block {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: clamp(2rem, 6vw, 5.75rem);
    background:
      linear-gradient(90deg, transparent 49.8%, rgba(149, 163, 165, 0.05) 50%, transparent 50.2%),
      linear-gradient(transparent 49.8%, rgba(149, 163, 165, 0.05) 50%, transparent 50.2%);
  }

  h1 {
    max-width: 11ch;
    margin: 1.3rem 0 1.5rem;
    font-family: var(--font-mono);
    font-size: clamp(3.1rem, 7vw, 6.9rem);
    font-weight: 700;
    letter-spacing: -0.075em;
    line-height: 0.88;
  }

  h1 span {
    display: block;
    color: var(--muted);
    font-size: 0.45em;
    font-weight: 500;
    letter-spacing: -0.045em;
    line-height: 1.5;
  }

  .role-line {
    margin: 0 0 1.4rem;
    color: var(--accent);
    font-family: var(--font-mono);
    font-size: clamp(0.76rem, 1.4vw, 0.95rem);
  }

  .role-line span {
    color: var(--dim);
  }

  .intro-copy {
    max-width: 40rem;
    margin: 0;
    color: var(--muted);
    font-size: clamp(1rem, 1.6vw, 1.2rem);
    line-height: 1.75;
  }

  .intro-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 2.2rem;
  }

  .identity-panel {
    margin: -1px -1px -1px 0;
  }

  .portrait-wrap {
    position: relative;
    padding: clamp(1.2rem, 3vw, 2rem);
  }

  .portrait-rulers {
    display: flex;
    justify-content: space-between;
    margin-bottom: 0.55rem;
    color: var(--dim);
    font-family: var(--font-mono);
    font-size: 0.55rem;
  }

  .portrait-frame {
    position: relative;
    aspect-ratio: 1;
    overflow: hidden;
    border: 1px solid var(--line-strong);
    background: var(--surface-raised);
  }

  .portrait-frame::after {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 55%, rgba(9, 13, 15, 0.45));
    content: "";
  }

  .portrait-frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(0.75) contrast(1.08);
  }

  .portrait-corner {
    position: absolute;
    z-index: 1;
    width: 1.1rem;
    height: 1.1rem;
    border-color: var(--accent);
  }

  .corner-a {
    top: 0.55rem;
    left: 0.55rem;
    border-top: 1px solid;
    border-left: 1px solid;
  }

  .corner-b {
    right: 0.55rem;
    bottom: 0.55rem;
    border-right: 1px solid;
    border-bottom: 1px solid;
  }

  .identity-data {
    margin: 0;
    border-top: 1px solid var(--line);
  }

  .identity-data div {
    display: grid;
    grid-template-columns: 4.2rem 1fr;
    border-bottom: 1px solid var(--line);
    font-family: var(--font-mono);
    font-size: 0.68rem;
  }

  .identity-data div:last-child {
    border-bottom: 0;
  }

  .identity-data dt,
  .identity-data dd {
    margin: 0;
    padding: 0.75rem 0.85rem;
  }

  .identity-data dt {
    border-right: 1px solid var(--line);
    color: var(--dim);
  }

  .identity-data dd {
    color: var(--muted);
  }

  .signal-grid,
  .contact-grid {
    display: grid;
    grid-template-columns: minmax(13rem, 0.38fr) minmax(0, 1fr);
    border: 1px solid var(--line);
    border-top: 0;
  }

  .signal-intro,
  .contact-grid > div:first-child {
    padding: clamp(1.5rem, 3vw, 2.5rem);
  }

  h2 {
    margin: 0.65rem 0 0;
    font-family: var(--font-mono);
    font-size: clamp(1.35rem, 2vw, 2rem);
    letter-spacing: -0.04em;
  }

  .signal-list {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    margin: 0;
    padding: 0;
    border-left: 1px solid var(--line);
    list-style: none;
  }

  .signal-list li {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.25rem 0.8rem;
    min-height: 8rem;
    align-content: center;
    border-right: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    padding: 1.25rem;
  }

  .signal-list li:nth-child(2n) {
    border-right: 0;
  }

  .signal-list li:nth-last-child(-n + 2) {
    border-bottom: 0;
  }

  .signal-list span {
    grid-row: span 2;
    color: var(--accent);
    font-family: var(--font-mono);
    font-size: 0.62rem;
  }

  .signal-list strong {
    font-family: var(--font-mono);
    font-size: 0.83rem;
    font-weight: 650;
    text-transform: uppercase;
  }

  .signal-list small {
    color: var(--dim);
    font-size: 0.78rem;
  }

  .social-links {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    border-left: 1px solid var(--line);
  }

  .social-links a {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 0.8rem;
    min-height: 8.5rem;
    border-right: 1px solid var(--line);
    padding: 1.25rem;
    transition: background-color 160ms ease, color 160ms ease;
  }

  .social-links a:last-child {
    border-right: 0;
  }

  .social-links a:hover {
    background: rgba(125, 249, 194, 0.06);
    color: var(--accent);
  }

  .social-links :global(.social-icon) {
    width: 1.15rem;
    height: 1.15rem;
  }

  .social-links strong,
  .social-links small {
    display: block;
  }

  .social-links strong {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    text-transform: uppercase;
  }

  .social-links small {
    margin-top: 0.25rem;
    overflow: hidden;
    color: var(--dim);
    font-family: var(--font-mono);
    font-size: 0.58rem;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .social-links i {
    color: var(--accent);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-style: normal;
  }

  @media (max-width: 900px) {
    .home-grid {
      grid-template-columns: minmax(0, 1fr) minmax(17rem, 0.65fr);
      min-height: auto;
    }

    .intro-block {
      padding: clamp(2rem, 5vw, 4rem);
    }

    .social-links {
      grid-template-columns: 1fr;
    }

    .social-links a {
      min-height: 5.5rem;
      border-right: 0;
      border-bottom: 1px solid var(--line);
    }

    .social-links a:last-child {
      border-bottom: 0;
    }
  }

  @media (max-width: 720px) {
    .home-main {
      padding: 1rem;
    }

    .home-grid,
    .signal-grid,
    .contact-grid {
      grid-template-columns: 1fr;
    }

    .intro-block {
      min-height: 31rem;
      padding: 2rem 1.35rem;
    }

    h1 {
      font-size: clamp(3rem, 16vw, 5.2rem);
    }

    .identity-panel {
      margin: -1px;
    }

    .portrait-wrap {
      display: grid;
      grid-template-columns: minmax(0, 18rem);
      justify-content: center;
    }

    .portrait-rulers {
      grid-column: 1;
    }

    .signal-list,
    .social-links {
      border-top: 1px solid var(--line);
      border-left: 0;
    }

    .signal-list li {
      min-height: 7rem;
    }
  }

  @media (max-width: 430px) {
    .signal-list {
      grid-template-columns: 1fr;
    }

    .signal-list li,
    .signal-list li:nth-child(2n),
    .signal-list li:nth-last-child(-n + 2) {
      border-right: 0;
      border-bottom: 1px solid var(--line);
    }

    .signal-list li:last-child {
      border-bottom: 0;
    }

    .intro-actions .action-link {
      width: 100%;
    }
  }
</style>
