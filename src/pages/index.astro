---
import Layout from "../layouts/Layout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import Linkedin from "../components/simple-icons/linkedin.astro";
import Github from "../components/simple-icons/github.astro";
import X from "../components/simple-icons/x.astro";
---

<Layout bodyClass="home-page">
  <div class="home-shell">
    <SiteHeader />

    <main id="main-content" class="home-main">
      <section class="identity" aria-labelledby="page-title">
        <p class="identity__kicker reveal">Software engineer · Indie hacker</p>
        <h1 id="page-title" class="identity__title reveal reveal--1">
          <span>Akshit</span>
          <span><em>Kr</em> Nagpal</span>
        </h1>

        <div class="identity__aside reveal reveal--2">
          <span class="identity__rule" aria-hidden="true"></span>
          <p>Full-stack engineer building useful software for people and agents.</p>
        </div>
      </section>

      <section class="portrait-panel reveal reveal--2" aria-label="About Akshit">
        <div class="portrait-panel__image-wrap">
          <img
            src="https://avatars.githubusercontent.com/u/15872348"
            alt="Akshit Kr Nagpal"
            width="460"
            height="460"
            class="portrait-panel__image"
          />
          <span class="portrait-panel__status">Building independently</span>
        </div>

        <div class="portrait-panel__copy">
          <p>
            Indie hacker and full-stack engineer. I build developer tools, ship side projects, and care deeply about clean code and great UX.
          </p>

          <div class="portrait-panel__actions">
            <a class="primary-link" href="/projects">Explore projects <span aria-hidden="true">→</span></a>
            <div class="social-links" aria-label="Social links">
              <a href="https://github.com/akshitkrnagpal" target="_blank" rel="noopener noreferrer">
                <Github class="social-links__icon" fill="currentColor" />
                <span>GitHub</span>
              </a>
              <a href="https://linkedin.com/in/akshitkrnagpal" target="_blank" rel="noopener noreferrer">
                <Linkedin class="social-links__icon" fill="currentColor" />
                <span>LinkedIn</span>
              </a>
              <a href="https://x.com/akshit_io" target="_blank" rel="noopener noreferrer">
                <X class="social-links__icon" fill="currentColor" />
                <span>X</span>
              </a>
            </div>
          </div>
        </div>
      </section>
    </main>

    <div class="ticker" aria-label="Areas of focus">
      <div class="ticker__track">
        <span>Developer tools</span><i aria-hidden="true"></i><span>Open source</span><i aria-hidden="true"></i><span>AI systems</span><i aria-hidden="true"></i><span>Great UX</span><i aria-hidden="true"></i><span>Developer tools</span><i aria-hidden="true"></i><span>Open source</span><i aria-hidden="true"></i><span>AI systems</span><i aria-hidden="true"></i><span>Great UX</span>
      </div>
    </div>
  </div>
</Layout>
