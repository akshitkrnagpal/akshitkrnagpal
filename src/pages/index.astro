---
import Layout from "../layouts/Layout.astro";
import Linkedin from "../components/simple-icons/linkedin.astro";
import Github from "../components/simple-icons/github.astro";
import X from "../components/simple-icons/x.astro";
---

<Layout>
  <a class="skip-link" href="#main-content">Skip to content</a>

  <div class="page-shell">
    <header class="site-header reveal">
      <a class="site-brand" href="/" aria-label="Akshit Kr Nagpal, home">
        <span class="site-brand-mark" aria-hidden="true">AKN</span>
        <span class="site-brand-label">Independent software engineer</span>
      </a>
      <p class="masthead-note">Portfolio / Selected practice</p>
      <nav class="site-nav" aria-label="Primary navigation">
        <a class="nav-link" href="/" aria-current="page">Index</a>
        <a class="nav-link" href="/projects">Projects</a>
      </nav>
    </header>

    <main id="main-content">
      <section class="hero" aria-labelledby="page-title">
        <p class="eyebrow reveal" style="--delay: 100ms">Software engineer · Indie hacker</p>
        <h1 id="page-title" class="display-title reveal" style="--delay: 160ms" aria-label="Akshit Kr Nagpal">
          Akshit Kr<br /><em>Nagpal</em>
        </h1>

        <div class="hero-grid">
          <div class="hero-statement reveal" style="--delay: 240ms">
            <p class="statement-lead">Building useful software with a sharp eye for systems, details, and the people using them.</p>
            <p class="statement-body">
              Indie hacker and full-stack engineer. I build developer tools, ship side projects, and care deeply about clean code and great UX.
            </p>
            <a class="rule-link" href="/projects">
              Explore selected projects
              <svg aria-hidden="true" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M5 19 19 5m0 0H8m11 0v11"></path>
              </svg>
            </a>
          </div>

          <dl class="practice-list reveal" style="--delay: 300ms">
            <div>
              <dt class="meta-label">Role</dt>
              <dd>Software Engineer</dd>
            </div>
            <div>
              <dt class="meta-label">Practice</dt>
              <dd>Full-stack development</dd>
            </div>
            <div>
              <dt class="meta-label">Focus</dt>
              <dd>Developer tools, open source, AI</dd>
            </div>
          </dl>

          <figure class="portrait reveal" style="--delay: 360ms">
            <div class="portrait-frame">
              <img
                src="https://avatars.githubusercontent.com/u/15872348"
                alt="Portrait of Akshit Kr Nagpal"
                width="460"
                height="460"
                loading="eager"
                fetchpriority="high"
              />
            </div>
            <figcaption class="figure-caption">Akshit Kr Nagpal / Software Engineer</figcaption>
          </figure>
        </div>
      </section>

      <section class="project-prompt reveal" style="--delay: 100ms" aria-labelledby="project-prompt-title">
        <div>
          <p class="section-label">Selected work</p>
          <h2 id="project-prompt-title" class="section-heading">Products, tools, and open-source experiments.</h2>
        </div>
        <div class="project-prompt-copy">
          <p>Explore the projects I maintain, from production products to focused utilities for developers.</p>
          <a class="rule-link" href="/projects">
            View project index
            <svg aria-hidden="true" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M5 12h14m-5-5 5 5-5 5"></path>
            </svg>
          </a>
        </div>
      </section>
    </main>

    <footer class="site-footer">
      <p class="footer-copy">Akshit Kr Nagpal / Software Engineer</p>
      <nav class="footer-links" aria-label="Social links">
        <a href="https://github.com/akshitkrnagpal" target="_blank" rel="noopener noreferrer" aria-label="GitHub (opens in a new tab)">
          <Github size={15} aria-hidden="true" />
          <span>GitHub</span>
        </a>
        <a href="https://linkedin.com/in/akshitkrnagpal" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn (opens in a new tab)">
          <Linkedin size={15} aria-hidden="true" />
          <span>LinkedIn</span>
        </a>
        <a href="https://x.com/akshit_io" target="_blank" rel="noopener noreferrer" aria-label="X (opens in a new tab)">
          <X size={14} aria-hidden="true" />
          <span>X</span>
        </a>
      </nav>
    </footer>
  </div>
</Layout>

<style>
  .hero {
    padding-top: clamp(3.5rem, 8vw, 8rem);
  }

  .hero .eyebrow {
    margin: 0 0 clamp(2.25rem, 5vw, 4.5rem);
  }

  .hero-grid {
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    gap: 1rem;
    align-items: start;
    margin-top: clamp(3rem, 7vw, 7rem);
    border-top: 1px solid var(--line-strong);
    padding-top: 1.15rem;
  }

  .hero-statement {
    grid-column: 1 / span 5;
    max-width: 35rem;
  }

  .statement-lead {
    max-width: 30rem;
    margin: 0 0 1.5rem;
    font-family: var(--font-display);
    font-size: clamp(1.9rem, 3.4vw, 3.3rem);
    letter-spacing: -0.025em;
    line-height: 1.02;
  }

  .statement-body {
    max-width: 28rem;
    margin: 0 0 2.25rem;
    color: var(--muted);
    font-size: clamp(1rem, 1.35vw, 1.17rem);
    line-height: 1.7;
  }

  .practice-list {
    grid-column: 7 / span 2;
    margin: 0;
  }

  .practice-list div {
    border-top: 1px solid var(--line);
    padding: 0.75rem 0 1.6rem;
  }

  .practice-list div:first-child {
    border-top: 0;
    padding-top: 0;
  }

  .practice-list dt,
  .practice-list dd {
    margin: 0;
  }

  .practice-list dd {
    margin-top: 0.38rem;
    font-size: 0.88rem;
    line-height: 1.45;
  }

  .portrait {
    grid-column: 9 / -1;
    margin: 0;
  }

  .portrait-frame {
    position: relative;
    overflow: hidden;
    aspect-ratio: 4 / 5;
    background: var(--paper-deep);
  }

  .portrait-frame::after {
    position: absolute;
    inset: 0;
    border: 1px solid rgba(17, 19, 16, 0.2);
    content: "";
    pointer-events: none;
  }

  .portrait-frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(100%) contrast(1.05);
    transform: scale(1.015);
    transition: filter 500ms ease, transform 700ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .portrait-frame:hover img {
    filter: grayscale(15%) contrast(1.02);
    transform: scale(1.045);
  }

  .figure-caption {
    display: flex;
    justify-content: space-between;
    margin-top: 0.7rem;
  }

  .project-prompt {
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    gap: 1rem;
    align-items: end;
    margin-top: clamp(7rem, 14vw, 14rem);
    border-top: 1px solid var(--line-strong);
    padding-top: 1rem;
  }

  .project-prompt > div:first-child {
    grid-column: span 8;
  }

  .project-prompt .section-label {
    margin: 0 0 clamp(2.5rem, 7vw, 7rem);
  }

  .project-prompt-copy {
    grid-column: 10 / -1;
    padding-bottom: 0.3rem;
  }

  .project-prompt-copy p {
    margin: 0 0 2rem;
    color: var(--muted);
    line-height: 1.7;
  }

  .footer-links a {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
  }

  @media (max-width: 62rem) {
    .hero-statement {
      grid-column: 1 / span 6;
    }

    .practice-list {
      grid-column: 7 / -1;
    }

    .portrait {
      grid-column: 7 / -1;
      margin-top: 3rem;
    }

    .project-prompt > div:first-child {
      grid-column: span 8;
    }

    .project-prompt-copy {
      grid-column: 9 / -1;
    }
  }

  @media (max-width: 48rem) {
    .hero {
      padding-top: 3.25rem;
    }

    .hero-grid {
      grid-template-columns: repeat(6, minmax(0, 1fr));
      margin-top: 3.5rem;
    }

    .hero-statement,
    .practice-list,
    .portrait {
      grid-column: 1 / -1;
    }

    .practice-list {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 0.75rem;
      margin-top: 3rem;
      border-top: 1px solid var(--line);
      padding-top: 0.8rem;
    }

    .practice-list div,
    .practice-list div:first-child {
      border: 0;
      padding: 0;
    }

    .portrait {
      margin-top: 3.5rem;
    }

    .portrait-frame {
      aspect-ratio: 5 / 4;
    }

    .project-prompt {
      grid-template-columns: 1fr;
      align-items: start;
      margin-top: 7rem;
    }

    .project-prompt > div:first-child,
    .project-prompt-copy {
      grid-column: 1;
    }

    .project-prompt .section-label {
      margin-bottom: 3rem;
    }

    .project-prompt-copy {
      margin-top: 2.5rem;
    }
  }

  @media (max-width: 30rem) {
    .practice-list {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
  }
</style>
