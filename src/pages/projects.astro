---
import Layout from "../layouts/Layout.astro";

const githubRepositories = [
  "akshitkrnagpal/typesensekit",
  "offerkit/offerkit",
  "akshitkrnagpal/edgepush",
  "akshitkrnagpal/revcat",
  "open-placeholder/open-placeholder",
  "akshitkrnagpal/secret-desk",
  "akshitkrnagpal/env-doctor",
] as const;

const githubHeaders: Record<string, string> = {
  Accept: "application/vnd.github+json",
  "X-GitHub-Api-Version": "2022-11-28",
};

if (import.meta.env.GITHUB_TOKEN) {
  githubHeaders.Authorization = `Bearer ${import.meta.env.GITHUB_TOKEN}`;
}

const githubStars = Object.fromEntries(
  await Promise.all(
    githubRepositories.map(async (repository) => {
      try {
        const response = await fetch(`https://api.github.com/repos/${repository}`, {
          headers: githubHeaders,
        });

        if (!response.ok) {
          console.warn(`Could not fetch GitHub stars for ${repository}: ${response.status}`);
          return [repository, null] as const;
        }

        const data = (await response.json()) as { stargazers_count: number };
        return [repository, data.stargazers_count] as const;
      } catch (error) {
        console.warn(`Could not fetch GitHub stars for ${repository}`, error);
        return [repository, null] as const;
      }
    }),
  ),
) as Record<string, number | null>;

const featuredProjects = [
  {
    name: "TypesenseKit",
    eyebrow: "Typesense CLI & MCP server",
    description:
      "95 typed Typesense operations for humans and AI agents—one CLI and MCP server, read-only by default.",
    tags: ["Typesense", "CLI", "MCP", "95 Operations"],
    labels: ["Active", "Open Source"],
    image: "https://typesensekit.vercel.app/images/typesensekit-robot-favicon-180.png",
    repo: "akshitkrnagpal/typesensekit",
    links: [
      { label: "Docs", href: "https://typesensekit.vercel.app", primary: true },
      { label: "GitHub", href: "https://github.com/akshitkrnagpal/typesensekit" },
    ],
  },
  {
    name: "PromptLens",
    eyebrow: "Autonomous AI reliability",
    description:
      "An autonomous reliability engineer for production LLM systems. Continuously evaluate behavior, catch regressions, investigate failures, and make confident release decisions.",
    tags: ["AI Reliability", "Continuous Evals", "Release Decisions"],
    labels: ["Active", "Early access"],
    image: "https://www.promptlens.io/icon-512.png",
    repo: null,
    links: [{ label: "Visit", href: "https://www.promptlens.io", primary: true }],
  },
  {
    name: "OfferKit",
    eyebrow: "Self-hostable promotion engine",
    description:
      "Agent-first promotion engine for coupons, loyalty, gift cards, referrals, and customer segments. Built for teams that need pricing and promo logic they can own.",
    tags: ["Commerce", "Promotions", "MCP"],
    labels: ["Active", "Open Source", "Self-hostable"],
    image: "https://raw.githubusercontent.com/offerkit/offerkit/main/apps/web/public/icon.png",
    repo: "offerkit/offerkit",
    links: [{ label: "GitHub", href: "https://github.com/offerkit/offerkit", primary: true }],
  },
  {
    name: "EdgePush",
    eyebrow: "Open-source push notifications",
    description:
      "Push notifications for iOS and Android on Cloudflare Workers. BYO APNs and FCM credentials, encrypted at rest. Free hosted tier or self-host on your own account.",
    tags: ["Push Notifications", "Cloudflare Workers", "AGPL-3.0"],
    labels: ["Open Source", "Self-hostable"],
    icon: "dot",
    iconBg: "#000000",
    iconText: "",
    iconColor: "#FF6B1A",
    repo: "akshitkrnagpal/edgepush",
    links: [
      { label: "Visit", href: "https://edgepush.dev", primary: true },
      { label: "GitHub", href: "https://github.com/akshitkrnagpal/edgepush" },
    ],
  },
  {
    name: "HookBell",
    eyebrow: "Instant webhook push notifications",
    description:
      "Never miss a webhook again. Get human-readable push notifications on your phone when webhooks fire from services like Stripe, Clerk, Supabase, and more.",
    tags: ["Webhooks", "Developer Tools", "Mobile"],
    labels: ["Production"],
    image: "https://hookbell.com/icon-512.png",
    repo: null,
    links: [{ label: "Visit", href: "https://hookbell.com", primary: true }],
  },
];

const featured = featuredProjects.map((project) => ({
  ...project,
  stars: project.repo ? githubStars[project.repo] : null,
}));

const smallerProjects = [
  {
    name: "revcat",
    description:
      "RevenueCat CLI with full v2 API coverage, OAuth login, and per-repo project context for agents and sandboxes.",
    tags: ["Go", "CLI", "RevenueCat"],
    repo: "akshitkrnagpal/revcat",
    href: "https://github.com/akshitkrnagpal/revcat",
    secondaryHref: "https://revcat.vercel.app",
    secondaryLabel: "Docs",
  },
  {
    name: "open-placeholder",
    description:
      "Self-hosted placeholder image generator. Generate custom placeholder images on the fly.",
    tags: ["Images", "Self-hosted"],
    repo: "open-placeholder/open-placeholder",
    href: "https://github.com/open-placeholder/open-placeholder",
  },
  {
    name: "secret-desk",
    description:
      "Vercel-like editing experience for Kubernetes secrets. Manage secrets with a clean, intuitive interface.",
    tags: ["Kubernetes", "DevOps"],
    repo: "akshitkrnagpal/secret-desk",
    href: "https://github.com/akshitkrnagpal/secret-desk",
  },
  {
    name: "env-doctor",
    description:
      "The .env file auditor every developer needs. Validate, lint, and catch issues in your environment files.",
    tags: ["CLI", "Developer Tools"],
    repo: "akshitkrnagpal/env-doctor",
    href: "https://github.com/akshitkrnagpal/env-doctor",
  },
];

const smaller = smallerProjects.map((project) => ({
  ...project,
  stars: githubStars[project.repo],
}));

const projectCount = featured.length + smaller.length;
const formatProjectIndex = (index: number) => String(index + 1).padStart(2, "0");
---

<Layout
  title="Projects – Akshit Kr Nagpal"
  description="Indie products, open-source tools, and focused experiments built by Akshit Kr Nagpal."
>
  <div class="studio-shell">
    <div class="projects-blob" aria-hidden="true"></div>
    <header>
      <nav class="site-nav" aria-label="Primary navigation">
        <a class="site-mark" href="/" aria-label="Akshit Kr Nagpal, home">Akshit / Portfolio</a>
        <a class="nav-link" href="/"><span aria-hidden="true">←</span> Home</a>
      </nav>
    </header>

    <main id="main-content">
      <header class="projects-hero">
        <div>
          <p class="eyebrow reveal">Selected work / 01—{String(projectCount).padStart(2, "0")}</p>
          <h1 class="display-type projects-title reveal"><span class="sr-only">Projects — </span>Things I’ve<br /><em>made happen.</em></h1>
        </div>
        <div class="hero-note reveal">
          <span aria-hidden="true">✦</span>
          <p>Indie products, open-source tools, and smaller experiments.</p>
        </div>
        <p class="projects-intro body-copy reveal">
          The featured few below get real maintenance; the rest are focused single-purpose utilities.
        </p>
      </header>

      <section class="featured-section" aria-labelledby="featured-heading">
        <div class="section-heading">
          <h2 id="featured-heading">Featured / maintained</h2>
          <span aria-hidden="true">↓</span>
        </div>

        <div class="featured-list">
          {featured.map((project, index) => (
            <article class="project-card">
              <div class="project-index" aria-hidden="true">{formatProjectIndex(index)}</div>
              <div class="project-visual">
                <div class="project-icon" style={`background: ${project.iconBg || "var(--white)"};`}>
                  {project.image ? (
                    <img src={project.image} alt={`${project.name} logo`} width="180" height="180" loading="lazy" />
                  ) : project.icon === "dot" ? (
                    <svg viewBox="0 0 64 64" aria-hidden="true"><circle cx="32" cy="32" r="14" fill={project.iconColor}></circle></svg>
                  ) : (
                    <span style={`color: ${project.iconColor};`}>{project.iconText}</span>
                  )}
                </div>
                <div class="project-sticker" aria-hidden="true">Built<br />to last</div>
              </div>

              <div class="project-content">
                <div class="project-topline">
                  <p>{project.eyebrow}</p>
                  {project.stars !== null && project.stars !== undefined ? (
                    <span class="stars" aria-label={`${project.stars} GitHub stars`}>
                      <svg viewBox="0 0 16 16" aria-hidden="true"><path d="M8 .25a.75.75 0 0 1 .673.418l1.882 3.815 4.21.612a.75.75 0 0 1 .416 1.279l-3.046 2.97.719 4.192a.75.75 0 0 1-1.088.791L8 12.347l-3.766 1.98a.75.75 0 0 1-1.088-.79l.72-4.194L.818 6.374a.75.75 0 0 1 .416-1.28l4.21-.611L7.327.668A.75.75 0 0 1 8 .25z"></path></svg>
                      {project.stars}
                    </span>
                  ) : null}
                </div>
                <h3>{project.name}</h3>
                <div class="project-labels" aria-label="Project status">
                  {project.labels.map((label) => <span>{label}</span>)}
                </div>
                <p class="project-description">{project.description}</p>
                <ul class="tag-list" aria-label="Technologies and project attributes">
                  {project.tags.map((tag) => <li>{tag}</li>)}
                </ul>
                <div class="project-links">
                  {project.links.map((link) => (
                    <a
                      href={link.href}
                      target="_blank"
                      rel="noopener noreferrer"
                      class:list={["button-link", { secondary: !link.primary }]}
                    >
                      {link.label} <span aria-hidden="true">↗</span>
                    </a>
                  ))}
                </div>
              </div>
            </article>
          ))}
        </div>
      </section>

      <section class="small-section" aria-labelledby="small-heading">
        <div class="section-heading">
          <h2 id="small-heading">Tools &amp; experiments</h2>
          <span>Small, sharp, useful.</span>
        </div>

        <div class="small-list">
          {smaller.map((project, index) => (
            <article class="small-project">
              <span class="small-index" aria-hidden="true">{formatProjectIndex(featured.length + index)}</span>
              <div>
                <div class="small-title-row">
                  <h3>{project.name}</h3>
                  {project.stars !== null && project.stars !== undefined ? (
                    <span class="stars" aria-label={`${project.stars} GitHub stars`}>
                      <svg viewBox="0 0 16 16" aria-hidden="true"><path d="M8 .25a.75.75 0 0 1 .673.418l1.882 3.815 4.21.612a.75.75 0 0 1 .416 1.279l-3.046 2.97.719 4.192a.75.75 0 0 1-1.088.791L8 12.347l-3.766 1.98a.75.75 0 0 1-1.088-.79l.72-4.194L.818 6.374a.75.75 0 0 1 .416-1.28l4.21-.611L7.327.668A.75.75 0 0 1 8 .25z"></path></svg>
                      {project.stars}
                    </span>
                  ) : null}
                </div>
                <p>{project.description}</p>
                <ul class="tag-list" aria-label="Technologies and project attributes">
                  {project.tags.map((tag) => <li>{tag}</li>)}
                </ul>
              </div>
              <div class="small-links">
                <a href={project.href} target="_blank" rel="noopener noreferrer">GitHub <span aria-hidden="true">↗</span></a>
                {project.secondaryHref ? (
                  <a href={project.secondaryHref} target="_blank" rel="noopener noreferrer">{project.secondaryLabel} <span aria-hidden="true">↗</span></a>
                ) : null}
              </div>
            </article>
          ))}
        </div>

        <a class="github-callout" href="https://github.com/akshitkrnagpal" target="_blank" rel="noopener noreferrer">
          <span>More code lives on</span>
          <strong>GitHub</strong>
          <span class="callout-arrow" aria-hidden="true">↗</span>
        </a>
      </section>
    </main>

    <footer class="studio-footer">
      <span>Akshit Kr Nagpal</span>
      <span>Indie products · Open source · Experiments</span>
    </footer>
  </div>
</Layout>

<style>
  .projects-blob {
    position: absolute;
    z-index: -1;
    top: 4rem;
    right: -9rem;
    width: 31rem;
    aspect-ratio: 1.1;
    border: 2px solid var(--ink);
    border-radius: 56% 44% 42% 58% / 44% 62% 38% 56%;
    background: var(--lilac);
    transform: rotate(-8deg);
  }

  .projects-hero {
    position: relative;
    display: grid;
    width: min(100% - 2rem, 76rem);
    margin: 0 auto;
    padding: clamp(5rem, 11vw, 10rem) 0 clamp(6rem, 10vw, 9rem);
    grid-template-columns: 1.2fr 0.8fr;
    gap: 2rem 5rem;
  }

  .projects-title {
    margin-top: 1rem;
    font-size: clamp(5.2rem, 11.5vw, 10rem);
  }

  .projects-title em {
    color: var(--tomato);
    font-weight: 400;
  }

  .projects-intro {
    max-width: 31rem;
    margin: 0;
    align-self: end;
  }

  .hero-note {
    position: relative;
    width: min(100%, 15rem);
    margin-top: 4rem;
    padding: 1.5rem;
    align-self: start;
    border: 2px solid var(--ink);
    background: var(--butter);
    box-shadow: 6px 6px 0 var(--ink);
    font-family: var(--font-display);
    font-size: 1.65rem;
    line-height: 1.05;
    transform: rotate(4deg);
  }

  .hero-note p {
    margin: 0.5rem 0 0;
  }

  .hero-note span {
    color: var(--tomato);
  }

  .featured-section,
  .small-section {
    width: min(100% - 2rem, 76rem);
    margin-inline: auto;
  }

  .section-heading {
    display: flex;
    padding: 0.9rem 0;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    border-top: 2px solid var(--ink);
    border-bottom: 2px solid var(--ink);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.13em;
    text-transform: uppercase;
  }

  .section-heading h2 {
    margin: 0;
    font: inherit;
  }

  .featured-list {
    display: grid;
    padding: clamp(3rem, 6vw, 5rem) 0 clamp(7rem, 12vw, 10rem);
    gap: clamp(4rem, 9vw, 8rem);
  }

  .project-card {
    position: relative;
    display: grid;
    padding: clamp(1rem, 2vw, 1.5rem);
    grid-template-columns: minmax(16rem, 0.72fr) minmax(0, 1.28fr);
    gap: clamp(2rem, 6vw, 6rem);
    border: 2px solid var(--ink);
    border-radius: 1.5rem;
    background: var(--white);
    box-shadow: 9px 9px 0 var(--ink);
  }

  .project-card:nth-child(even) {
    grid-template-columns: minmax(0, 1.28fr) minmax(16rem, 0.72fr);
  }

  .project-card:nth-child(even) .project-visual {
    grid-column: 2;
  }

  .project-card:nth-child(even) .project-content {
    grid-row: 1;
    grid-column: 1;
  }

  .project-card:nth-child(3n + 1) .project-visual { background: var(--butter); }
  .project-card:nth-child(3n + 2) .project-visual { background: var(--lilac); }
  .project-card:nth-child(3n) .project-visual { background: #dca58f; }

  .project-index {
    position: absolute;
    z-index: 2;
    top: -1.35rem;
    left: 1.5rem;
    display: grid;
    width: 3.2rem;
    aspect-ratio: 1;
    place-items: center;
    border: 2px solid var(--ink);
    border-radius: 50%;
    background: var(--tomato-dark);
    color: var(--white);
    font-size: 0.75rem;
    font-weight: 600;
    transform: rotate(-9deg);
  }

  .project-visual {
    position: relative;
    display: grid;
    min-height: 24rem;
    place-items: center;
    overflow: hidden;
    border: 2px solid var(--ink);
    border-radius: 1rem 5rem 1rem 1rem;
  }

  .project-card:nth-child(even) .project-visual {
    border-radius: 5rem 1rem 1rem 1rem;
  }

  .project-icon {
    display: grid;
    width: clamp(8rem, 13vw, 11rem);
    aspect-ratio: 1;
    overflow: hidden;
    place-items: center;
    border: 2px solid var(--ink);
    border-radius: 2.4rem;
    box-shadow: 6px 6px 0 var(--ink);
    transform: rotate(-4deg);
  }

  .project-icon img,
  .project-icon svg {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .project-icon span {
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 4rem;
    font-weight: 600;
  }

  .project-sticker {
    position: absolute;
    right: 1rem;
    bottom: 1rem;
    display: grid;
    width: 4.5rem;
    aspect-ratio: 1;
    place-items: center;
    border: 2px solid var(--ink);
    border-radius: 50%;
    background: var(--white);
    font-size: 0.62rem;
    font-weight: 600;
    line-height: 1.15;
    text-align: center;
    text-transform: uppercase;
    transform: rotate(11deg);
  }

  .project-content {
    display: flex;
    padding: clamp(1rem, 2vw, 2rem) clamp(0rem, 2vw, 1rem);
    justify-content: center;
    flex-direction: column;
  }

  .project-topline,
  .small-title-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .project-topline p {
    margin: 0;
    color: var(--tomato-dark);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .stars {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    color: var(--muted);
    font-size: 0.72rem;
  }

  .stars svg {
    width: 0.8rem;
    fill: currentColor;
  }

  .project-content h3,
  .small-project h3 {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 400;
    letter-spacing: -0.035em;
  }

  .project-content h3 {
    margin-top: 0.75rem;
    font-size: clamp(3.5rem, 6vw, 5.7rem);
    line-height: 0.95;
  }

  .project-labels {
    display: flex;
    margin-top: 1rem;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .project-labels span,
  .tag-list li {
    border: 1.5px solid var(--ink);
    border-radius: 999px;
    font-size: 0.66rem;
    font-weight: 600;
    letter-spacing: 0.06em;
  }

  .project-labels span {
    padding: 0.25rem 0.6rem;
    background: var(--paper-deep);
    text-transform: uppercase;
  }

  .project-description {
    max-width: 38rem;
    margin: 1.6rem 0;
    color: var(--muted);
    font-size: clamp(0.96rem, 1.4vw, 1.1rem);
    line-height: 1.65;
  }

  .tag-list {
    display: flex;
    margin: 0;
    padding: 0;
    flex-wrap: wrap;
    gap: 0.45rem;
    list-style: none;
  }

  .tag-list li {
    padding: 0.3rem 0.65rem;
    border-color: rgb(33 27 24 / 30%);
    color: var(--muted);
  }

  .project-links {
    display: flex;
    margin-top: 2rem;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .small-section {
    margin-bottom: 8rem;
  }

  .small-list {
    border-bottom: 2px solid var(--ink);
  }

  .small-project {
    display: grid;
    padding: 2rem 0;
    align-items: start;
    grid-template-columns: 3rem minmax(0, 1fr) auto;
    gap: clamp(1rem, 4vw, 3rem);
    border-bottom: 1.5px solid rgb(33 27 24 / 30%);
  }

  .small-project:last-child {
    border-bottom: 0;
  }

  .small-index {
    color: var(--tomato-dark);
    font-size: 0.72rem;
    font-weight: 600;
  }

  .small-project h3 {
    font-size: clamp(2rem, 4vw, 3.2rem);
    line-height: 1;
  }

  .small-project p {
    max-width: 39rem;
    margin: 0.75rem 0 1rem;
    color: var(--muted);
  }

  .small-links {
    display: flex;
    padding-top: 0.35rem;
    align-items: flex-end;
    flex-direction: column;
    gap: 0.65rem;
  }

  .small-links a {
    display: inline-flex;
    min-height: 2.75rem;
    padding: 0.65rem 0.75rem;
    align-items: center;
    border: 1.5px solid var(--ink);
    border-radius: 999px;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.07em;
    text-decoration: none;
    text-transform: uppercase;
  }

  .github-callout {
    position: relative;
    display: grid;
    margin-top: clamp(4rem, 8vw, 7rem);
    padding: clamp(2rem, 5vw, 4rem);
    overflow: hidden;
    border: 2px solid var(--ink);
    border-radius: 6rem 1.5rem 1.5rem 1.5rem;
    background: var(--tomato-dark);
    box-shadow: 8px 8px 0 var(--ink);
    color: var(--white);
    text-decoration: none;
    transition: transform 180ms ease, box-shadow 180ms ease;
  }

  .github-callout:hover {
    transform: translate(-3px, -3px);
    box-shadow: 12px 12px 0 var(--ink);
  }

  .github-callout > span:first-child {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .github-callout strong {
    font-family: var(--font-display);
    font-size: clamp(4.5rem, 12vw, 9rem);
    font-weight: 400;
    letter-spacing: -0.04em;
    line-height: 0.9;
  }

  .callout-arrow {
    position: absolute;
    right: clamp(1.5rem, 4vw, 3rem);
    bottom: clamp(1.5rem, 4vw, 3rem);
    font-size: 3rem;
  }

  @media (max-width: 52rem) {
    .projects-hero {
      grid-template-columns: 1fr;
    }

    .hero-note {
      margin-top: 0;
      justify-self: end;
    }

    .projects-intro {
      margin-top: 2rem;
    }

    .project-card,
    .project-card:nth-child(even) {
      grid-template-columns: 1fr;
    }

    .project-card:nth-child(even) .project-visual,
    .project-card:nth-child(even) .project-content {
      grid-row: auto;
      grid-column: auto;
    }

    .project-visual {
      min-height: 19rem;
    }
  }

  @media (max-width: 40rem) {
    .projects-blob {
      top: 10rem;
      right: -13rem;
      width: 24rem;
    }

    .projects-hero,
    .featured-section,
    .small-section {
      width: min(100% - 1.25rem, 76rem);
    }

    .projects-title {
      font-size: clamp(4.7rem, 22vw, 7rem);
    }

    .hero-note {
      width: 12rem;
      font-size: 1.35rem;
    }

    .project-card {
      padding: 0.75rem;
      gap: 0.75rem;
      box-shadow: 6px 6px 0 var(--ink);
    }

    .project-visual {
