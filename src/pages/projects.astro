---
import Layout from "../layouts/Layout.astro";
import SiteFooter from "../components/SiteFooter.astro";
import SiteHeader from "../components/SiteHeader.astro";
import Github from "../components/simple-icons/github.astro";

const githubRepositories = [
  "akshitkrnagpal/typesensekit",
  "offerkit/offerkit",
  "akshitkrnagpal/edgepush",
  "akshitkrnagpal/revcat",
  "open-placeholder/open-placeholder",
  "akshitkrnagpal/secret-desk",
  "akshitkrnagpal/env-doctor",
] as const;

const githubHeaders: Record<string, string> = {
  Accept: "application/vnd.github+json",
  "X-GitHub-Api-Version": "2022-11-28",
};

if (import.meta.env.GITHUB_TOKEN) {
  githubHeaders.Authorization = `Bearer ${import.meta.env.GITHUB_TOKEN}`;
}

const githubStars = Object.fromEntries(
  await Promise.all(
    githubRepositories.map(async (repository) => {
      try {
        const response = await fetch(`https://api.github.com/repos/${repository}`, {
          headers: githubHeaders,
        });

        if (!response.ok) {
          console.warn(`Could not fetch GitHub stars for ${repository}: ${response.status}`);
          return [repository, null] as const;
        }

        const data = (await response.json()) as { stargazers_count: number };
        return [repository, data.stargazers_count] as const;
      } catch (error) {
        console.warn(`Could not fetch GitHub stars for ${repository}`, error);
        return [repository, null] as const;
      }
    }),
  ),
) as Record<string, number | null>;

const featuredProjects = [
  {
    name: "TypesenseKit",
    eyebrow: "Typesense CLI & MCP server",
    description:
      "95 typed Typesense operations for humans and AI agents—one CLI and MCP server, read-only by default.",
    tags: ["Typesense", "CLI", "MCP", "95 Operations"],
    labels: ["Active", "Open Source"],
    image: "https://typesensekit.vercel.app/images/typesensekit-robot-favicon-180.png",
    repo: "akshitkrnagpal/typesensekit",
    links: [
      { label: "Docs", href: "https://typesensekit.vercel.app", primary: true },
      { label: "GitHub", href: "https://github.com/akshitkrnagpal/typesensekit" },
    ],
  },
  {
    name: "PromptLens",
    eyebrow: "Autonomous AI reliability",
    description:
      "An autonomous reliability engineer for production LLM systems. Continuously evaluate behavior, catch regressions, investigate failures, and make confident release decisions.",
    tags: ["AI Reliability", "Continuous Evals", "Release Decisions"],
    labels: ["Active", "Early access"],
    image: "https://www.promptlens.io/icon-512.png",
    repo: null,
    links: [{ label: "Visit", href: "https://www.promptlens.io", primary: true }],
  },
  {
    name: "OfferKit",
    eyebrow: "Self-hostable promotion engine",
    description:
      "Agent-first promotion engine for coupons, loyalty, gift cards, referrals, and customer segments. Built for teams that need pricing and promo logic they can own.",
    tags: ["Commerce", "Promotions", "MCP"],
    labels: ["Active", "Open Source", "Self-hostable"],
    icon: "text",
    iconText: "%",
    repo: "offerkit/offerkit",
    links: [{ label: "GitHub", href: "https://github.com/offerkit/offerkit", primary: true }],
  },
  {
    name: "EdgePush",
    eyebrow: "Open-source push notifications",
    description:
      "Push notifications for iOS and Android on Cloudflare Workers. BYO APNs and FCM credentials, encrypted at rest. Free hosted tier or self-host on your own account.",
    tags: ["Push Notifications", "Cloudflare Workers", "AGPL-3.0"],
    labels: ["Open Source", "Self-hostable"],
    icon: "dot",
    iconText: "",
    repo: "akshitkrnagpal/edgepush",
    links: [
      { label: "Visit", href: "https://edgepush.dev", primary: true },
      { label: "GitHub", href: "https://github.com/akshitkrnagpal/edgepush" },
    ],
  },
  {
    name: "HookBell",
    eyebrow: "Instant webhook push notifications",
    description:
      "Never miss a webhook again. Get human-readable push notifications on your phone when webhooks fire from services like Stripe, Clerk, Supabase, and more.",
    tags: ["Webhooks", "Developer Tools", "Mobile"],
    labels: ["Production"],
    image: "https://hookbell.com/icon-512.png",
    repo: null,
    links: [{ label: "Visit", href: "https://hookbell.com", primary: true }],
  },
];

const featured = featuredProjects.map((project) => ({
  ...project,
  stars: project.repo ? githubStars[project.repo] : null,
}));

const smallerProjects = [
  {
    name: "revcat",
    description:
      "RevenueCat CLI with full v2 API coverage, OAuth login, and per-repo project context for agents and sandboxes.",
    tags: ["Go", "CLI", "RevenueCat"],
    repo: "akshitkrnagpal/revcat",
    href: "https://github.com/akshitkrnagpal/revcat",
    secondaryHref: "https://revcat.vercel.app",
    secondaryLabel: "Docs",
  },
  {
    name: "open-placeholder",
    description:
      "Self-hosted placeholder image generator. Generate custom placeholder images on the fly.",
    tags: ["Images", "Self-hosted"],
    repo: "open-placeholder/open-placeholder",
    href: "https://github.com/open-placeholder/open-placeholder",
  },
  {
    name: "secret-desk",
    description:
      "Vercel-like editing experience for Kubernetes secrets. Manage secrets with a clean, intuitive interface.",
    tags: ["Kubernetes", "DevOps"],
    repo: "akshitkrnagpal/secret-desk",
    href: "https://github.com/akshitkrnagpal/secret-desk",
  },
  {
    name: "env-doctor",
    description:
      "The .env file auditor every developer needs. Validate, lint, and catch issues in your environment files.",
    tags: ["CLI", "Developer Tools"],
    repo: "akshitkrnagpal/env-doctor",
    href: "https://github.com/akshitkrnagpal/env-doctor",
  },
];

const smaller = smallerProjects.map((project) => ({
  ...project,
  stars: githubStars[project.repo],
}));
---

<Layout
  title="Projects – Akshit Kr Nagpal"
  description="Indie products, open-source tools, and focused experiments built by Akshit Kr Nagpal."
>
  <div class="projects-shell">
    <SiteHeader current="projects" />

    <main class="frame projects-main">
      <header class="projects-intro enter">
        <div class="projects-intro__index mono" aria-hidden="true">02 / WORK</div>
        <div>
          <p class="eyebrow">Shipped systems</p>
          <h1>Projects<span>.</span></h1>
        </div>
        <p class="projects-intro__copy">
          Indie products, open-source tools, and smaller experiments. The featured few below get real maintenance; the rest are focused single-purpose utilities.
        </p>
        <div class="projects-intro__count mono">
          <strong>{String(featured.length + smaller.length).padStart(2, "0")}</strong>
          <span>PROJECTS<br />INDEXED</span>
        </div>
      </header>

      <section class="featured enter enter--1" aria-labelledby="featured-heading">
        <div class="section-heading">
          <p class="eyebrow" id="featured-heading">Featured / maintained</p>
          <span class="mono">{String(featured.length).padStart(2, "0")} ENTRIES</span>
        </div>

        <div class="project-list">
          {featured.map((project, index) => (
            <article class="project-row">
              <div class="project-row__number mono">{String(index + 1).padStart(2, "0")}</div>

              <div class={`project-row__visual project-row__visual--${project.icon ?? "image"}`}>
                {project.image ? (
                  <img src={project.image} alt="" width="72" height="72" loading="lazy" />
                ) : project.icon === "dot" ? (
                  <span class="edge-dot" aria-hidden="true"></span>
                ) : (
                  <span aria-hidden="true">{project.iconText}</span>
                )}
              </div>

              <div class="project-row__body">
                <div class="project-row__titleline">
                  <h2>{project.name}</h2>
                  {project.stars !== null && project.stars !== undefined ? (
                    <span class="star-count mono" aria-label={`${project.stars} GitHub stars`}>
                      <span aria-hidden="true">★</span> {project.stars}
                    </span>
                  ) : null}
                </div>
                <p class="project-row__eyebrow mono">{project.eyebrow}</p>
                <p class="project-row__description">{project.description}</p>
                <div class="tag-list" aria-label="Technologies">
                  {project.tags.map((tag) => <span>{tag}</span>)}
                </div>
              </div>

              <div class="project-row__aside">
                <div class="label-list">
                  {project.labels.map((label) => (
                    <span><i class:list={{ "status-dot": label === "Active" || label === "Production" }}></i>{label}</span>
                  ))}
                </div>
                <div class="project-links">
                  {project.links.map((link) => (
                    <a
                      href={link.href}
                      target="_blank"
                      rel="noopener noreferrer"
                      class:list={{ "project-link--primary": link.primary }}
                    >
                      {link.label}
                      <span class="link-arrow" aria-hidden="true">↗</span>
                    </a>
                  ))}
                </div>
              </div>
            </article>
          ))}
        </div>
      </section>

      <section class="utilities enter enter--2" aria-labelledby="utilities-heading">
        <div class="section-heading">
          <p class="eyebrow" id="utilities-heading">Tools / experiments</p>
          <span class="mono">{String(smaller.length).padStart(2, "0")} ENTRIES</span>
        </div>

        <div class="utility-list">
          <div class="utility-head mono" aria-hidden="true">
            <span>ID / PROJECT</span>
            <span>FUNCTION</span>
            <span>STACK</span>
            <span>LINK</span>
          </div>
          {smaller.map((project, index) => (
            <article class="utility-row">
              <div class="utility-row__name">
                <span class="mono">{String(index + featured.length + 1).padStart(2, "0")}</span>
                <h2>{project.name}</h2>
                {project.stars !== null && project.stars !== undefined ? (
                  <span class="star-count mono" aria-label={`${project.stars} GitHub stars`}><span aria-hidden="true">★</span> {project.stars}</span>
                ) : null}
              </div>
              <p>{project.description}</p>
              <div class="tag-list">
                {project.tags.map((tag) => <span>{tag}</span>)}
              </div>
              <div class="utility-row__links">
                <a href={project.href} target="_blank" rel="noopener noreferrer">GitHub <span class="link-arrow" aria-hidden="true">↗</span></a>
                {project.secondaryHref ? (
                  <a href={project.secondaryHref} target="_blank" rel="noopener noreferrer">{project.secondaryLabel} <span class="link-arrow" aria-hidden="true">↗</span></a>
                ) : null}
              </div>
            </article>
          ))}
        </div>
      </section>

      <aside class="github-cta enter enter--3">
        <div>
          <Github fill="currentColor" aria-hidden="true" />
          <p class="eyebrow">Source archive</p>
        </div>
        <p>More repositories, experiments, and works in progress live on GitHub.</p>
        <a href="https://github.com/akshitkrnagpal" target="_blank" rel="noopener noreferrer">
          View more on GitHub
          <span class="link-arrow" aria-hidden="true">↗</span>
        </a>
      </aside>
    </main>

    <SiteFooter />
  </div>
</Layout>

<style>
  .projects-main {
    border-inline: 1px solid var(--line);
  }

  .projects-intro {
    align-items: end;
    border-bottom: 1px solid var(--line);
    display: grid;
    gap: clamp(1.5rem, 4vw, 5rem);
    grid-template-columns: 96px minmax(280px, 0.8fr) minmax(280px, 1fr) 100px;
    min-height: 370px;
    padding: 4rem clamp(1.25rem, 3.5vw, 3.75rem) 3.5rem;
  }

  .projects-intro__index {
    align-self: start;
    color: var(--quiet);
    font-size: 0.6rem;
    letter-spacing: 0.08em;
    writing-mode: vertical-rl;
  }

  .projects-intro h1 {
    font-size: clamp(4.5rem, 9vw, 8.4rem);
    font-weight: 500;
    letter-spacing: -0.07em;
    line-height: 0.8;
    margin-top: 2rem;
  }

  .projects-intro h1 span {
    color: var(--accent);
  }

  .projects-intro__copy {
    color: var(--muted);
    font-size: clamp(1rem, 1.3vw, 1.2rem);
    line-height: 1.65;
    max-width: 580px;
  }

  .projects-intro__count {
    border-left: 1px solid var(--line);
    padding-left: 1.25rem;
  }

  .projects-intro__count strong {
    color: var(--accent);
    display: block;
    font-size: 1.8rem;
    font-weight: 500;
    line-height: 1;
    margin-bottom: 0.75rem;
  }

  .projects-intro__count span {
    color: var(--quiet);
    font-size: 0.55rem;
    letter-spacing: 0.08em;
    line-height: 1.5;
  }

  .featured,
  .utilities {
    padding: 3rem clamp(1.25rem, 3.5vw, 3.75rem) 5rem;
  }

  .featured {
    border-bottom: 1px solid var(--line);
  }

  .section-heading {
    align-items: center;
    display: flex;
    justify-content: space-between;
    margin-bottom: 1.5rem;
  }

  .section-heading > span {
    color: var(--quiet);
    font-size: 0.58rem;
    letter-spacing: 0.1em;
  }

  .project-list {
    border-top: 1px solid var(--line-strong);
  }

  .project-row {
    border-bottom: 1px solid var(--line);
    display: grid;
    gap: clamp(1rem, 2.5vw, 2.5rem);
    grid-template-columns: 34px 72px minmax(0, 1fr) 190px;
    padding: 2rem 0;
    position: relative;
    transition: background-color 160ms ease, padding 160ms ease;
  }

  .project-row::before {
    background: var(--accent);
    bottom: -1px;
    content: "";
    left: 0;
    position: absolute;
    top: -1px;
    transform: scaleY(0);
    transition: transform 160ms ease;
    width: 2px;
  }

  .project-row:hover {
    background: rgba(255, 255, 255, 0.015);
    padding-inline: 1rem;
  }

  .project-row:hover::before {
    transform: scaleY(1);
  }

  .project-row__number {
    color: var(--quiet);
    font-size: 0.6rem;
    padding-top: 0.35rem;
  }

  .project-row__visual {
    align-items: center;
    align-self: start;
    background: var(--surface-raised);
    border: 1px solid var(--line);
    display: flex;
    height: 72px;
    justify-content: center;
    overflow: hidden;
    width: 72px;
  }

  .project-row__visual img {
    height: 100%;
    object-fit: cover;
    width: 100%;
  }

  .project-row__visual--text {
    background: #171717;
    font-family: var(--font-mono);
    font-size: 1.65rem;
  }

  .project-row__visual--dot {
    background: #050505;
  }

  .edge-dot {
    background: var(--accent);
    border-radius: 50%;
    height: 24px;
    width: 24px;
  }

  .project-row__titleline {
    align-items: baseline;
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
  }

  .project-row h2,
  .utility-row h2 {
    font-size: clamp(1.35rem, 2vw, 1.85rem);
    font-weight: 500;
    letter-spacing: -0.035em;
  }

  .star-count {
    color: var(--muted);
    font-size: 0.62rem;
  }

  .star-count > span {
    color: var(--accent);
    font-size: 0.58rem;
  }

  .project-row__eyebrow {
    color: var(--accent);
    font-size: 0.62rem;
    letter-spacing: 0.04em;
    margin-top: 0.15rem;
    text-transform: uppercase;
  }

  .project-row__description {
    color: var(--muted);
    line-height: 1.6;
    margin-top: 1rem;
    max-width: 680px;
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 1.2rem;
  }

  .tag-list span {
    border: 1px solid var(--line);
    color: var(--quiet);
    font-family: var(--font-mono);
    font-size: 0.55rem;
    letter-spacing: 0.04em;
    padding: 0.28rem 0.48rem;
    text-transform: uppercase;
  }

  .project-row__aside {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  .label-list {
    align-items: flex-start;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .label-list span {
    align-items: center;
    color: var(--quiet);
    display: inline-flex;
    font-family: var(--font-mono);
    font-size: 0.54rem;
    gap: 0.45rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .label-list span + span::before {
    color: var(--line-strong);
    content: "/";
    margin-right: 0.1rem;
  }

  .label-list i:not(.status-dot) {
    display: none;
  }

  .project-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 2rem;
  }

  .project-links a,
  .utility-row__links a {
    align-items: center;
    border: 1px solid var(--line-strong);
    color: var(--muted);
    display: inline-flex;
    font-family: var(--font-mono);
    font-size: 0.6rem;
    gap: 0.75rem;
    letter-spacing: 0.05em;
    min-height: 34px;
    padding-inline: 0.7rem;
    text-transform: uppercase;
    transition: border-color 160ms ease, color 160ms ease, transform 160ms ease;
  }

  .project-links a:hover,
  .utility-row__links a:hover {
    border-color: var(--accent);
    color: var(--ink);
    transform: translateY(-2px);
  }

  .project-links .project-link--primary {
    background: var(--ink);
    border-color: var(--ink);
    color: var(--paper);
  }

  .utility-list {
    border-top: 1px solid var(--line-strong);
  }

  .utility-head,
  .utility-row {
    display: grid;
    gap: 1.5rem;
    grid-template-columns: minmax(190px, 0.75fr) minmax(260px, 1.35fr) minmax(190px, 0.9fr) 130px;
  }

  .utility-head {
    border-bottom: 1px solid var(--line);
    color: var(--quiet);
    font-size: 0.55rem;
    letter-spacing: 0.08em;
    padding-block: 0.75rem;
  }

  .utility-row {
    align-items: center;
    border-bottom: 1px solid var(--line);
    padding-block: 1.5rem;
    transition: background-color 160ms ease, padding 160ms ease;
  }

  .utility-row:hover {
    background: rgba(255, 255, 255, 0.015);
    padding-inline: 0.75rem;
  }

  .utility-row__name {
    align-items: baseline;
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
  }

  .utility-row__name > .mono:first-child {
    color: var(--quiet);
    font-size: 0.58rem;
  }

  .utility-row h2 {
    font-size: 1.05rem;
  }

  .utility-row > p {
    color: var(--muted);
    font-size: 0.84rem;
    line-height: 1.55;
  }

  .utility-row .tag-list {
    margin: 0;
  }

  .utility-row__links {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }

  .utility-row__links a {
    justify-content: space-between;
  }

  .github-cta {
    align-items: center;
    background: var(--surface);
    border-top: 1px solid var(--line);
    display: grid;
    gap: 2rem;
    grid-template-columns: minmax(220px, 0.8fr) minmax(280px, 1fr) auto;
    padding: 2.5rem clamp(1.25rem, 3.5vw, 3.75rem);
  }

  .github-cta > div {
    align-items: center;
    display: flex;
    gap: 1rem;
  }

  .github-cta svg {
    height: 24px;
    width: 24px;
  }

  .github-cta > p {
    color: var(--muted);
    font-size: 0.9rem;
  }

  .github-cta > a {
    align-items: center;
    background: var(--accent);
    color: #111;
    display: inline-flex;
    font-family: var(--font-mono);
    font-size: 0.62rem;
    font-weight: 600;
    gap: 1.5rem;
    letter-spacing: 0.05em;
    padding: 0.9rem 1rem;
    text-transform: uppercase;
  }

  @media (max-width: 1060px) {
    .projects-intro {
      grid-template-columns: minmax(280px, 1fr) minmax(280px, 1fr) 80px;
    }

    .projects-intro__index {
      display: none;
    }

    .project-row {
      grid-template-columns: 28px 64px minmax(0, 1fr);
    }

    .project-row__visual {
      height: 64px;
      width: 64px;
    }

    .project-row__aside {
      display: grid;
      gap: 1rem;
      grid-column: 3;
      grid-template-columns: 1fr auto;
    }

    .project-links {
      margin: 0;
    }

    .utility-head {
      display: none;
    }

    .utility-row {
      grid-template-columns: minmax(190px, 0.7fr) minmax(280px, 1.3fr) 130px;
    }

    .utility-row > .tag-list {
      display: none;
    }
  }

  @media (max-width: 760px) {
    .projects-intro {
      align-items: start;
      display: grid;
      grid-template-columns: 1fr auto;
      min-height: 0;
      padding: 4rem 1rem 3rem;
    }

    .projects-intro > div:nth-child(2) {
      grid-column: 1 / 3;
    }

    .projects-intro__copy {
      grid-column: 1 / 3;
    }

    .projects-intro__count {
      display: none;
    }

    .projects-intro h1 {
      font-size: clamp(4rem, 20vw, 6rem);
      margin-top: 1.5rem;
    }

    .featured,
    .utilities {
      padding: 2.5rem 1rem 4rem;
    }

    .project-row {
      gap: 1rem;
      grid-template-columns: 24px 52px minmax(0, 1fr);
      padding-block: 1.5rem;
    }

    .project-row__visual {
      height: 52px;
      width: 52px;
    }

    .project-row__body {
      grid-column: 3;
    }

    .project-row__aside {
      display: block;
      grid-column: 3;
    }

    .project-links {
      margin-top: 1.2rem;
    }

    .utility-row {
      gap: 0.85rem;
      grid-template-columns: minmax(0, 1fr) auto;
    }

    .utility-row > p {
      grid-column: 1 / 3;
    }

    .utility-row__links {
      grid-column: 1 / 3;
      flex-direction: row;
    }

    .github-cta {
      align-items: start;
      display: flex;
      flex-direction: column;
      padding: 2.5rem 1rem;
    }
  }

  @media (max-width: 440px) {
    .project-row {
      grid-template-columns: 20px minmax(0, 1fr);
    }

    .project-row__visual {
      display: none;
    }

    .project-row__body,
    .project-row__aside {
      grid-column: 2;
    }

    .section-heading > span {
      display: none;
    }
  }
</style>
