---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import typesensekitImage from "../assets/site/typesensekit.png";
import promptlensImage from "../assets/site/promptlens.png";
import hookbellImage from "../assets/site/hookbell.png";

const githubRepositories = [
  "typesensekit/typesensekit",
  "offerkit/offerkit",
  "akshitkrnagpal/edgepush",
  "akshitkrnagpal/revcat",
  "open-placeholder/open-placeholder",
  "akshitkrnagpal/secret-desk",
  "akshitkrnagpal/env-doctor",
] as const;

const githubHeaders: Record<string, string> = {
  Accept: "application/vnd.github+json",
  "X-GitHub-Api-Version": "2022-11-28",
};

// Keep static builds deterministic when GitHub's unauthenticated API limit is
// exhausted. Live values replace these whenever the API is available.
const githubStarFallbacks: Record<(typeof githubRepositories)[number], number> = {
  "typesensekit/typesensekit": 2,
  "offerkit/offerkit": 30,
  "akshitkrnagpal/edgepush": 5,
  "akshitkrnagpal/revcat": 3,
  "open-placeholder/open-placeholder": 13,
  "akshitkrnagpal/secret-desk": 2,
  "akshitkrnagpal/env-doctor": 1,
};
let githubFallbackWarningShown = false;

if (import.meta.env.GITHUB_TOKEN) {
  githubHeaders.Authorization = `Bearer ${import.meta.env.GITHUB_TOKEN}`;
}

const githubStars = Object.fromEntries(
  await Promise.all(
    githubRepositories.map(async (repository) => {
      try {
        const response = await fetch(`https://api.github.com/repos/${repository}`, {
          headers: githubHeaders,
        });

        if (!response.ok) {
          if (!githubFallbackWarningShown) {
            console.warn(`GitHub stars are unavailable (${response.status}); using cached values for this build.`);
            githubFallbackWarningShown = true;
          }
          return [repository, githubStarFallbacks[repository]] as const;
        }

        const data = (await response.json()) as { stargazers_count: number };
        return [repository, data.stargazers_count] as const;
      } catch (error) {
        if (!githubFallbackWarningShown) {
          console.warn("GitHub stars are unavailable; using cached values for this build.", error);
          githubFallbackWarningShown = true;
        }
        return [repository, githubStarFallbacks[repository]] as const;
      }
    }),
  ),
) as Record<string, number | null>;

const featuredProjects = [
  {
    slug: "typesensekit",
    name: "TypesenseKit",
    eyebrow: "Typesense CLI & MCP server",
    description:
      "95 typed Typesense operations for humans and AI agents—one CLI and MCP server, read-only by default.",
    tags: ["Typesense", "CLI", "MCP", "95 Operations"],
    labels: ["Active", "Open Source"],
    image: typesensekitImage,
    scene: "terminal",
    proof: "95 typed operations",
    repo: "typesensekit/typesensekit",
    links: [
      { label: "Docs", href: "https://typesensekit.vercel.app", primary: true },
      { label: "GitHub", href: "https://github.com/typesensekit/typesensekit" },
    ],
  },
  {
    slug: "promptlens",
    name: "PromptLens",
    eyebrow: "Autonomous AI reliability",
    description:
      "An autonomous reliability engineer for production LLM systems. Continuously evaluate behavior, catch regressions, investigate failures, and make confident release decisions.",
    tags: ["AI Reliability", "Continuous Evals", "Release Decisions"],
    labels: ["Active", "Early access"],
    image: promptlensImage,
    scene: "evaluation",
    proof: "Continuous evaluation",
    repo: null,
    links: [{ label: "Visit", href: "https://www.promptlens.io", primary: true }],
  },
  {
    slug: "offerkit",
    name: "OfferKit",
    eyebrow: "Self-hostable promotion engine",
    description:
      "Agent-first promotion engine for coupons, loyalty, gift cards, referrals, and customer segments. Built for teams that need pricing and promo logic they can own.",
    tags: ["Commerce", "Promotions", "MCP"],
    labels: ["Active", "Open Source", "Self-hostable"],
    icon: "text",
    iconBg: "#111111",
    iconText: "%",
    iconColor: "#F5F0E8",
    scene: "promotion",
    proof: "Rules you can own",
    repo: "offerkit/offerkit",
    links: [{ label: "GitHub", href: "https://github.com/offerkit/offerkit", primary: true }],
  },
  {
    slug: "edgepush",
    name: "EdgePush",
    eyebrow: "Open-source push notifications",
    description:
      "Push notifications for iOS and Android on Cloudflare Workers. BYO APNs and FCM credentials, encrypted at rest. Free hosted tier or self-host on your own account.",
    tags: ["Push Notifications", "Cloudflare Workers", "AGPL-3.0"],
    labels: ["Open Source", "Self-hostable"],
    icon: "dot",
    iconBg: "#000000",
    iconText: "",
    iconColor: "#FF6B1A",
    scene: "delivery",
    proof: "APNs + FCM at the edge",
    repo: "akshitkrnagpal/edgepush",
    links: [
      { label: "Visit", href: "https://edgepush.dev", primary: true },
      { label: "GitHub", href: "https://github.com/akshitkrnagpal/edgepush" },
    ],
  },
  {
    slug: "hookbell",
    name: "HookBell",
    eyebrow: "Instant webhook push notifications",
    description:
      "Never miss a webhook again. Get human-readable push notifications on your phone when webhooks fire from services like Stripe, Clerk, Supabase, and more.",
    tags: ["Webhooks", "Developer Tools", "Mobile"],
    labels: ["Production"],
    image: hookbellImage,
    scene: "webhook",
    proof: "Webhook to phone",
    repo: null,
    links: [{ label: "Visit", href: "https://hookbell.com", primary: true }],
  },
];

const featured = featuredProjects.map((project) => ({
  ...project,
  stars: project.repo ? githubStars[project.repo] : null,
}));

const smallerProjects = [
  {
    name: "revcat",
    description:
      "RevenueCat CLI with full v2 API coverage, OAuth login, and per-repo project context for agents and sandboxes.",
    tags: ["Go", "CLI", "RevenueCat"],
    repo: "akshitkrnagpal/revcat",
    href: "https://github.com/akshitkrnagpal/revcat",
    secondaryHref: "https://revcat.vercel.app",
    secondaryLabel: "Docs",
  },
  {
    name: "open-placeholder",
    description:
      "Self-hosted placeholder image generator. Generate custom placeholder images on the fly.",
    tags: ["Images", "Self-hosted"],
    repo: "open-placeholder/open-placeholder",
    href: "https://github.com/open-placeholder/open-placeholder",
  },
  {
    name: "secret-desk",
    description:
      "Vercel-like editing experience for Kubernetes secrets. Manage secrets with a clean, intuitive interface.",
    tags: ["Kubernetes", "DevOps"],
    repo: "akshitkrnagpal/secret-desk",
    href: "https://github.com/akshitkrnagpal/secret-desk",
  },
  {
    name: "env-doctor",
    description:
      "The .env file auditor every developer needs. Validate, lint, and catch issues in your environment files.",
    tags: ["CLI", "Developer Tools"],
    repo: "akshitkrnagpal/env-doctor",
    href: "https://github.com/akshitkrnagpal/env-doctor",
  },
];

const smaller = smallerProjects.map((project) => ({
  ...project,
  stars: githubStars[project.repo],
}));

const projectCount = featured.length + smaller.length;
const formatProjectIndex = (index: number) => String(index + 1).padStart(2, "0");
---

<Layout
  title="Projects – Akshit Kr Nagpal"
  description="Indie products, open-source tools, and focused experiments built by Akshit Kr Nagpal."
  ogImage="/og-projects.png"
  ogImageAlt="Selected products and open-source tools built by Akshit Kr Nagpal"
>
  <div class="studio-shell">
    <div class="projects-blob" aria-hidden="true"></div>
    <header>
      <nav class="site-nav" aria-label="Primary navigation">
        <a class="site-mark" href="/" aria-label="Akshit Kr Nagpal, home">Akshit / Portfolio</a>
        <a class="nav-link" href="/"><span aria-hidden="true">←</span> Home</a>
      </nav>
    </header>

    <main id="main-content" tabindex="-1">
      <header class="projects-hero">
        <div>
          <p class="eyebrow reveal">Selected work / 01—{String(projectCount).padStart(2, "0")}</p>
          <h1 class="display-type projects-title reveal"><span class="sr-only">Projects — </span>Things I’ve<br /><em>made happen.</em></h1>
        </div>
        <div class="hero-note reveal">
          <span aria-hidden="true">✦</span>
          <p>Indie products, open-source tools, and smaller experiments.</p>
        </div>
        <p class="projects-intro body-copy reveal">
          The featured few below get real maintenance; the rest are focused single-purpose utilities.
        </p>
      </header>

      <section class="featured-section" aria-labelledby="featured-heading">
        <div class="section-heading">
          <h2 id="featured-heading">Featured / maintained</h2>
          <span aria-hidden="true">↓</span>
        </div>

        <div class="featured-list">
          {featured.map((project, index) => (
            <article class="project-card" id={project.slug}>
              <div class="project-index" aria-hidden="true">{formatProjectIndex(index)}</div>
              <div class="project-visual" aria-hidden="true">
                <div class:list={["product-scene", `scene-${project.scene}`]}>
                  {project.scene === "terminal" ? (
                    <div class="terminal-window">
                      <div class="window-bar"><span></span><span></span><span></span></div>
                      <code><b>$</b> tsk documents.search</code>
                      <code class="terminal-muted">collection: products · 12 hits</code>
                      <span class="scene-status">✓ typed · read-only</span>
                    </div>
                  ) : project.scene === "evaluation" ? (
                    <div class="evaluation-window">
                      <span class="scene-kicker">Release evaluation</span>
                      <strong>98.7%</strong>
                      <div class="score-track"><span></span></div>
                      <div class="signal-row"><span>Behavior</span><b>Passing</b></div>
                      <div class="signal-row"><span>Regressions</span><b>0 found</b></div>
                    </div>
                  ) : project.scene === "promotion" ? (
                    <div class="promotion-window">
                      <span class="scene-kicker">Promotion rule</span>
                      <strong>SAVE20</strong>
                      <div class="rule-row"><span>Cart over</span><b>€100</b></div>
                      <div class="rule-row"><span>Discount</span><b>20%</b></div>
                      <span class="scene-status">Active · 42 redemptions</span>
                    </div>
                  ) : project.scene === "delivery" ? (
                    <div class="delivery-window">
                      <span class="scene-kicker">Push delivery</span>
                      <div class="delivery-route"><b>API</b><i>→</i><b>Edge</b><i>→</i><b>Phone</b></div>
                      <strong>Delivered</strong>
                      <span class="scene-status">184 ms · APNs</span>
                    </div>
                  ) : (
                    <div class="webhook-window">
                      <span class="scene-kicker">Live webhooks</span>
                      <div class="event-row"><i></i><span>payment.succeeded</span><b>now</b></div>
                      <div class="event-row"><i></i><span>user.created</span><b>2m</b></div>
                      <div class="event-row"><i></i><span>invoice.paid</span><b>8m</b></div>
                    </div>
                  )}
                </div>
                <div class="project-icon" style={`background: ${project.iconBg || "var(--white)"};`}>
                  {project.image ? (
                    <Image src={project.image} alt="" width={180} height={180} format="webp" quality={84} loading="lazy" decoding="async" />
                  ) : project.icon === "dot" ? (
                    <svg viewBox="0 0 64 64" aria-hidden="true"><circle cx="32" cy="32" r="14" fill={project.iconColor}></circle></svg>
                  ) : (
                    <span style={`color: ${project.iconColor};`}>{project.iconText}</span>
                  )}
                </div>
                <div class="project-proof">{project.proof}</div>
              </div>

              <div class="project-content">
                <div class="project-topline">
                  <p>{project.eyebrow}</p>
                  {project.stars !== null && project.stars !== undefined ? (
                    <span class="stars" aria-label={`${project.stars} GitHub stars`}>
                      <svg viewBox="0 0 16 16" aria-hidden="true"><path d="M8 .25a.75.75 0 0 1 .673.418l1.882 3.815 4.21.612a.75.75 0 0 1 .416 1.279l-3.046 2.97.719 4.192a.75.75 0 0 1-1.088.791L8 12.347l-3.766 1.98a.75.75 0 0 1-1.088-.79l.72-4.194L.818 6.374a.75.75 0 0 1 .416-1.28l4.21-.611L7.327.668A.75.75 0 0 1 8 .25z"></path></svg>
                      {project.stars}
                    </span>
                  ) : null}
                </div>
                <h3>{project.name}</h3>
                <ul class="project-labels" aria-label="Project status">
                  {project.labels.map((label) => <li>{label}</li>)}
                </ul>
                <p class="project-description">{project.description}</p>
                <ul class="tag-list" aria-label="Technologies and project attributes">
                  {project.tags.map((tag) => <li>{tag}</li>)}
                </ul>
                <div class="project-links">
                  {project.links.map((link) => (
                    <a
                      href={link.href}
                      target="_blank"
                      rel="noopener noreferrer"
                      class:list={["button-link", { secondary: !link.primary }]}
                    >
                      {link.label} <span aria-hidden="true">↗</span><span class="sr-only"> (opens in a new tab)</span>
                    </a>
                  ))}
                </div>
              </div>
            </article>
          ))}
        </div>
      </section>

      <section class="small-section" aria-labelledby="small-heading">
        <div class="section-heading">
          <h2 id="small-heading">Tools &amp; experiments</h2>
          <span>Small, sharp, useful.</span>
        </div>

        <div class="small-list">
          {smaller.map((project, index) => (
            <article class="small-project">
              <span class="small-index" aria-hidden="true">{formatProjectIndex(featured.length + index)}</span>
              <div>
                <div class="small-title-row">
                  <h3>{project.name}</h3>
                  {project.stars !== null && project.stars !== undefined ? (
                    <span class="stars" aria-label={`${project.stars} GitHub stars`}>
                      <svg viewBox="0 0 16 16" aria-hidden="true"><path d="M8 .25a.75.75 0 0 1 .673.418l1.882 3.815 4.21.612a.75.75 0 0 1 .416 1.279l-3.046 2.97.719 4.192a.75.75 0 0 1-1.088.791L8 12.347l-3.766 1.98a.75.75 0 0 1-1.088-.79l.72-4.194L.818 6.374a.75.75 0 0 1 .416-1.28l4.21-.611L7.327.668A.75.75 0 0 1 8 .25z"></path></svg>
                      {project.stars}
                    </span>
                  ) : null}
                </div>
                <p>{project.description}</p>
                <ul class="tag-list" aria-label="Technologies and project attributes">
                  {project.tags.map((tag) => <li>{tag}</li>)}
                </ul>
              </div>
              <div class="small-links">
                <a href={project.href} target="_blank" rel="noopener noreferrer">GitHub <span aria-hidden="true">↗</span><span class="sr-only"> (opens in a new tab)</span></a>
                {project.secondaryHref ? (
                  <a href={project.secondaryHref} target="_blank" rel="noopener noreferrer">{project.secondaryLabel} <span aria-hidden="true">↗</span><span class="sr-only"> (opens in a new tab)</span></a>
                ) : null}
              </div>
            </article>
          ))}
        </div>

        <a class="github-callout" href="https://github.com/akshitkrnagpal" target="_blank" rel="noopener noreferrer">
          <span>More code lives on</span>
          <strong>GitHub</strong>
          <span class="callout-arrow" aria-hidden="true">↗</span>
          <span class="sr-only"> (opens in a new tab)</span>
        </a>
      </section>
    </main>

    <footer class="studio-footer">
      <span>Akshit Kr Nagpal</span>
      <span>Indie products · Open source · Experiments</span>
    </footer>
  </div>
</Layout>

<style>
  .projects-blob {
    position: absolute;
    z-index: -1;
    top: 4rem;
    right: -9rem;
    width: 31rem;
    aspect-ratio: 1.1;
    border: 2px solid var(--ink);
    border-radius: 56% 44% 42% 58% / 44% 62% 38% 56%;
    background: var(--lilac);
    transform: rotate(-8deg);
  }

  .projects-hero {
    position: relative;
    display: grid;
    width: min(100% - 2rem, 76rem);
    margin: 0 auto;
    padding: clamp(5rem, 11vw, 10rem) 0 clamp(6rem, 10vw, 9rem);
    grid-template-columns: 1.2fr 0.8fr;
    gap: 2rem 5rem;
  }

  .projects-title {
    margin-top: 1rem;
    font-size: clamp(5.2rem, 11.5vw, 10rem);
  }

  .projects-title em {
    color: var(--tomato);
    font-weight: 400;
  }

  .projects-intro {
    max-width: 31rem;
    margin: 0;
    align-self: end;
  }

  .hero-note {
    position: relative;
    width: min(100%, 15rem);
    margin-top: 4rem;
    padding: 1.5rem;
    align-self: start;
    border: 2px solid var(--ink);
    background: var(--butter);
    box-shadow: 6px 6px 0 var(--ink);
    font-family: var(--font-display);
    font-size: 1.65rem;
    line-height: 1.05;
    transform: rotate(4deg);
  }

  .hero-note p {
    margin: 0.5rem 0 0;
  }

  .hero-note span {
    color: var(--tomato);
  }

  .featured-section,
  .small-section {
    width: min(100% - 2rem, 76rem);
    margin-inline: auto;
  }

  .section-heading {
    display: flex;
    padding: 0.9rem 0;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    border-top: 2px solid var(--ink);
    border-bottom: 2px solid var(--ink);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.13em;
    text-transform: uppercase;
  }

  .section-heading h2 {
    margin: 0;
    font: inherit;
  }

  .featured-list {
    display: grid;
    padding: clamp(3rem, 6vw, 5rem) 0 clamp(7rem, 12vw, 10rem);
    gap: clamp(4rem, 9vw, 8rem);
  }

  .project-card {
    position: relative;
    display: grid;
    padding: clamp(1rem, 2vw, 1.5rem);
    grid-template-columns: minmax(16rem, 0.72fr) minmax(0, 1.28fr);
    gap: clamp(2rem, 6vw, 6rem);
    border: 2px solid var(--ink);
    border-radius: 1.5rem;
    background: var(--white);
    box-shadow: 9px 9px 0 var(--ink);
    scroll-margin-top: 2rem;
  }

  .project-card:nth-child(even) {
    grid-template-columns: minmax(0, 1.28fr) minmax(16rem, 0.72fr);
  }

  .project-card:nth-child(even) .project-visual {
    grid-column: 2;
  }

  .project-card:nth-child(even) .project-content {
    grid-row: 1;
    grid-column: 1;
  }

  .project-card:nth-child(3n + 1) .project-visual { background: var(--butter); }
  .project-card:nth-child(3n + 2) .project-visual { background: var(--lilac); }
  .project-card:nth-child(3n) .project-visual { background: #dca58f; }

  .project-index {
    position: absolute;
    z-index: 2;
    top: -1.35rem;
    left: 1.5rem;
    display: grid;
    width: 3.2rem;
    aspect-ratio: 1;
    place-items: center;
    border: 2px solid var(--ink);
    border-radius: 50%;
    background: var(--tomato-dark);
    color: var(--white);
    font-size: 0.75rem;
    font-weight: 600;
    transform: rotate(-9deg);
  }

  .project-visual {
    position: relative;
    display: grid;
    min-height: 24rem;
    place-items: center;
    overflow: hidden;
    border: 2px solid var(--ink);
    border-radius: 1rem 5rem 1rem 1rem;
  }

  .project-card:nth-child(even) .project-visual {
    border-radius: 5rem 1rem 1rem 1rem;
  }

  .product-scene {
    display: grid;
    width: calc(100% - 3rem);
    max-width: 21rem;
    place-items: center;
  }

  .terminal-window,
  .evaluation-window,
  .promotion-window,
  .delivery-window,
  .webhook-window {
    display: flex;
    width: 100%;
    min-height: 13.5rem;
    padding: 1.25rem;
    justify-content: center;
    flex-direction: column;
    border: 2px solid var(--ink);
    border-radius: 1rem;
    background: var(--white);
    box-shadow: 7px 7px 0 var(--ink);
    transform: rotate(-2deg);
  }

  .terminal-window {
    background: var(--ink);
    color: var(--white);
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    transform: rotate(2deg);
  }

  .window-bar {
    display: flex;
    margin-bottom: 1.5rem;
    gap: 0.4rem;
  }

  .window-bar span {
    width: 0.55rem;
    aspect-ratio: 1;
    border-radius: 50%;
    background: var(--tomato);
  }

  .window-bar span:nth-child(2) { background: var(--butter); }
  .window-bar span:nth-child(3) { background: #6cac83; }

  .terminal-window code {
    font-size: clamp(0.68rem, 1vw, 0.78rem);
    white-space: nowrap;
  }

  .terminal-window code b {
    color: var(--butter);
  }

  .terminal-muted {
    margin-top: 0.65rem;
    color: #c8bfb4;
  }

  .scene-kicker {
    margin-bottom: 0.55rem;
    color: var(--tomato-dark);
    font-size: 0.66rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .evaluation-window > strong,
  .promotion-window > strong,
  .delivery-window > strong {
    font-family: var(--font-display);
    font-size: 3rem;
    font-weight: 400;
    letter-spacing: -0.03em;
    line-height: 1;
  }

  .score-track {
    height: 0.7rem;
    margin: 1rem 0;
    overflow: hidden;
    border: 1.5px solid var(--ink);
    border-radius: 999px;
    background: var(--paper-deep);
  }

  .score-track span {
    display: block;
    width: 89%;
    height: 100%;
    background: var(--leaf);
  }

  .signal-row,
  .rule-row,
  .event-row {
    display: flex;
    padding: 0.5rem 0;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    border-top: 1px solid rgb(33 27 24 / 22%);
    font-size: 0.7rem;
  }

  .signal-row b {
    color: var(--leaf);
  }

  .promotion-window {
    background: #fff3d0;
    transform: rotate(1.5deg);
  }

  .promotion-window > strong {
    margin-bottom: 1rem;
    color: var(--tomato-dark);
  }

  .scene-status {
    display: inline-flex;
    width: fit-content;
    margin-top: 1rem;
    padding: 0.35rem 0.55rem;
    border: 1.5px solid currentColor;
    border-radius: 999px;
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .delivery-window {
    background: #e9f4ee;
  }

  .delivery-route {
    display: flex;
    margin: 1rem 0 1.4rem;
    align-items: center;
    justify-content: space-between;
    gap: 0.4rem;
  }

  .delivery-route b {
    padding: 0.45rem;
    border: 1.5px solid var(--ink);
    border-radius: 0.5rem;
    background: var(--white);
    font-size: 0.65rem;
  }

  .delivery-route i {
    font-style: normal;
  }

  .delivery-window > strong {
    color: var(--leaf);
  }

