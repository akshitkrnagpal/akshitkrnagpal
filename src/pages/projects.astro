---
import Layout from "../layouts/Layout.astro";

const githubRepositories = [
  "akshitkrnagpal/typesensekit",
  "offerkit/offerkit",
  "akshitkrnagpal/edgepush",
  "akshitkrnagpal/revcat",
  "open-placeholder/open-placeholder",
  "akshitkrnagpal/secret-desk",
  "akshitkrnagpal/env-doctor",
] as const;

const githubHeaders: Record<string, string> = {
  Accept: "application/vnd.github+json",
  "X-GitHub-Api-Version": "2022-11-28",
};

if (import.meta.env.GITHUB_TOKEN) {
  githubHeaders.Authorization = `Bearer ${import.meta.env.GITHUB_TOKEN}`;
}

const githubStars = Object.fromEntries(
  await Promise.all(
    githubRepositories.map(async (repository) => {
      try {
        const response = await fetch(`https://api.github.com/repos/${repository}`, {
          headers: githubHeaders,
        });

        if (!response.ok) {
          console.warn(`Could not fetch GitHub stars for ${repository}: ${response.status}`);
          return [repository, null] as const;
        }

        const data = (await response.json()) as { stargazers_count: number };
        return [repository, data.stargazers_count] as const;
      } catch (error) {
        console.warn(`Could not fetch GitHub stars for ${repository}`, error);
        return [repository, null] as const;
      }
    }),
  ),
) as Record<string, number | null>;

const featuredProjects = [
  {
    name: "TypesenseKit",
    eyebrow: "Typesense CLI & MCP server",
    description:
      "95 typed Typesense operations for humans and AI agents—one CLI and MCP server, read-only by default.",
    tags: ["Typesense", "CLI", "MCP", "95 Operations"],
    labels: ["Active", "Open Source"],
    image: "https://typesensekit.vercel.app/images/typesensekit-robot-favicon-180.png",
    repo: "akshitkrnagpal/typesensekit",
    links: [
      { label: "Docs", href: "https://typesensekit.vercel.app", primary: true },
      { label: "GitHub", href: "https://github.com/akshitkrnagpal/typesensekit" },
    ],
  },
  {
    name: "PromptLens",
    eyebrow: "Autonomous AI reliability",
    description:
      "An autonomous reliability engineer for production LLM systems. Continuously evaluate behavior, catch regressions, investigate failures, and make confident release decisions.",
    tags: ["AI Reliability", "Continuous Evals", "Release Decisions"],
    labels: ["Active", "Early access"],
    image: "https://www.promptlens.io/icon-512.png",
    repo: null,
    links: [{ label: "Visit", href: "https://www.promptlens.io", primary: true }],
  },
  {
    name: "OfferKit",
    eyebrow: "Self-hostable promotion engine",
    description:
      "Agent-first promotion engine for coupons, loyalty, gift cards, referrals, and customer segments. Built for teams that need pricing and promo logic they can own.",
    tags: ["Commerce", "Promotions", "MCP"],
    labels: ["Active", "Open Source", "Self-hostable"],
    icon: "text",
    iconBg: "#111111",
    iconText: "%",
    iconColor: "#F5F0E8",
    repo: "offerkit/offerkit",
    links: [{ label: "GitHub", href: "https://github.com/offerkit/offerkit", primary: true }],
  },
  {
    name: "EdgePush",
    eyebrow: "Open-source push notifications",
    description:
      "Push notifications for iOS and Android on Cloudflare Workers. BYO APNs and FCM credentials, encrypted at rest. Free hosted tier or self-host on your own account.",
    tags: ["Push Notifications", "Cloudflare Workers", "AGPL-3.0"],
    labels: ["Open Source", "Self-hostable"],
    icon: "dot",
    iconBg: "#000000",
    iconText: "",
    iconColor: "#FF6B1A",
    repo: "akshitkrnagpal/edgepush",
    links: [
      { label: "Visit", href: "https://edgepush.dev", primary: true },
      { label: "GitHub", href: "https://github.com/akshitkrnagpal/edgepush" },
    ],
  },
  {
    name: "HookBell",
    eyebrow: "Instant webhook push notifications",
    description:
      "Never miss a webhook again. Get human-readable push notifications on your phone when webhooks fire from services like Stripe, Clerk, Supabase, and more.",
    tags: ["Webhooks", "Developer Tools", "Mobile"],
    labels: ["Production"],
    image: "https://hookbell.com/icon-512.png",
    repo: null,
    links: [{ label: "Visit", href: "https://hookbell.com", primary: true }],
  },
];

const featured = featuredProjects.map((project) => ({
  ...project,
  stars: project.repo ? githubStars[project.repo] : null,
}));

const smallerProjects = [
  {
    name: "revcat",
    description:
      "RevenueCat CLI with full v2 API coverage, OAuth login, and per-repo project context for agents and sandboxes.",
    tags: ["Go", "CLI", "RevenueCat"],
    repo: "akshitkrnagpal/revcat",
    href: "https://github.com/akshitkrnagpal/revcat",
    secondaryHref: "https://revcat.vercel.app",
    secondaryLabel: "Docs",
  },
  {
    name: "open-placeholder",
    description:
      "Self-hosted placeholder image generator. Generate custom placeholder images on the fly.",
    tags: ["Images", "Self-hosted"],
    repo: "open-placeholder/open-placeholder",
    href: "https://github.com/open-placeholder/open-placeholder",
  },
  {
    name: "secret-desk",
    description:
      "Vercel-like editing experience for Kubernetes secrets. Manage secrets with a clean, intuitive interface.",
    tags: ["Kubernetes", "DevOps"],
    repo: "akshitkrnagpal/secret-desk",
    href: "https://github.com/akshitkrnagpal/secret-desk",
  },
  {
    name: "env-doctor",
    description:
      "The .env file auditor every developer needs. Validate, lint, and catch issues in your environment files.",
    tags: ["CLI", "Developer Tools"],
    repo: "akshitkrnagpal/env-doctor",
    href: "https://github.com/akshitkrnagpal/env-doctor",
  },
];

const smaller = smallerProjects.map((project) => ({
  ...project,
  stars: githubStars[project.repo],
}));
---

<Layout title="Projects – Akshit Kr Nagpal" description="Indie products, open-source tools, and focused software experiments by Akshit Kr Nagpal.">
  <a class="skip-link" href="#main-content">Skip to content</a>

  <div class="page-shell">
    <header class="site-header reveal">
      <a class="site-brand" href="/" aria-label="Akshit Kr Nagpal, home">
        <span class="site-brand-mark" aria-hidden="true">AKN</span>
        <span class="site-brand-label">Independent software engineer</span>
      </a>
      <p class="masthead-note">Portfolio / Project index</p>
      <nav class="site-nav" aria-label="Primary navigation">
        <a class="nav-link" href="/">Index</a>
        <a class="nav-link" href="/projects" aria-current="page">Projects</a>
      </nav>
    </header>

    <main id="main-content">
      <header class="projects-hero">
        <div class="projects-heading">
          <p class="eyebrow reveal" style="--delay: 100ms">Shipped / Maintained / Open source</p>
          <h1 class="editorial-title reveal" style="--delay: 160ms" aria-label="Project index">Project<br /><em>index</em></h1>
        </div>
        <p class="projects-intro reveal" style="--delay: 240ms">
          Indie products, open-source tools, and smaller experiments. The featured few below get real maintenance; the rest are focused single-purpose utilities.
        </p>
      </header>

      <section class="projects-section" aria-labelledby="featured-heading">
        <div class="section-masthead reveal">
          <p class="section-label">01 / Featured</p>
          <h2 id="featured-heading">Selected projects</h2>
          <p>{featured.length.toString().padStart(2, "0")} entries</p>
        </div>

        <ol class="project-ledger">
          {featured.map((project, index) => (
            <li class="reveal" style={`--delay: ${Math.min(index * 70, 280)}ms`}>
              <article class="project-row">
                <div class="project-number">
                  <span class="project-index">{(index + 1).toString().padStart(2, "0")}</span>
                  <div class="project-mark" style={`background: ${project.iconBg || "var(--paper-deep)"};`}>
                    {project.image ? (
                      <img src={project.image} alt="" width="72" height="72" loading="lazy" />
                    ) : project.icon === "dot" ? (
                      <svg viewBox="0 0 72 72" aria-hidden="true">
                        <circle cx="36" cy="36" r="15" fill={project.iconColor} />
                      </svg>
                    ) : (
                      <span style={`color: ${project.iconColor};`}>{project.iconText}</span>
                    )}
                  </div>
                </div>

                <div class="project-identity">
                  <p class="project-eyebrow">{project.eyebrow}</p>
                  <h3>{project.name}</h3>
                  <div class="project-labels" aria-label="Project status">
                    {project.labels.map((label) => <span class="project-label">{label}</span>)}
                  </div>
                </div>

                <div class="project-detail">
                  <p class="project-description">{project.description}</p>
                  <ul class="tag-list" aria-label="Technologies and topics">
                    {project.tags.map((tag) => <li class="tag">{tag}</li>)}
                  </ul>
                </div>

                <div class="project-actions">
                  {project.stars !== null && project.stars !== undefined ? (
                    <span class="star-count" aria-label={`${project.stars} GitHub stars`}>
                      <svg aria-hidden="true" fill="currentColor" viewBox="0 0 16 16"><path d="M8 .25a.75.75 0 0 1 .673.418l1.882 3.815 4.21.612a.75.75 0 0 1 .416 1.279l-3.046 2.97.719 4.192a.75.75 0 0 1-1.088.791L8 12.347l-3.766 1.98a.75.75 0 0 1-1.088-.79l.72-4.194L.818 6.374a.75.75 0 0 1 .416-1.28l4.21-.611L7.327.668A.75.75 0 0 1 8 .25z"></path></svg>
                      {project.stars}
                    </span>
                  ) : null}
                  <div class="action-links">
                    {project.links.map((link) => (
                      <a class={link.primary ? "rule-link" : "text-link"} href={link.href} target="_blank" rel="noopener noreferrer">
                        {link.label}
                        <span class="sr-only"> (opens in a new tab)</span>
                        {link.primary ? (
                          <svg aria-hidden="true" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M5 19 19 5m0 0H8m11 0v11"></path>
                          </svg>
                        ) : null}
                      </a>
                    ))}
                  </div>
                </div>
              </article>
            </li>
          ))}
        </ol>
      </section>

      <section class="projects-section smaller-section" aria-labelledby="smaller-heading">
        <div class="section-masthead reveal">
          <p class="section-label">02 / Archive</p>
          <h2 id="smaller-heading">Tools &amp; experiments</h2>
          <p>{smaller.length.toString().padStart(2, "0")} entries</p>
        </div>

        <div class="smaller-grid">
          {smaller.map((project, index) => (
            <article class="small-project reveal" style={`--delay: ${Math.min(index * 70, 210)}ms`}>
              <div class="small-project-heading">
                <span class="project-index">{(index + 1).toString().padStart(2, "0")}</span>
                {project.stars !== null && project.stars !== undefined ? (
                  <span class="star-count" aria-label={`${project.stars} GitHub stars`}>
                    <svg aria-hidden="true" fill="currentColor" viewBox="0 0 16 16"><path d="M8 .25a.75.75 0 0 1 .673.418l1.882 3.815 4.21.612a.75.75 0 0 1 .416 1.279l-3.046 2.97.719 4.192a.75.75 0 0 1-1.088.791L8 12.347l-3.766 1.98a.75.75 0 0 1-1.088-.79l.72-4.194L.818 6.374a.75.75 0 0 1 .416-1.28l4.21-.611L7.327.668A.75.75 0 0 1 8 .25z"></path></svg>
                    {project.stars}
                  </span>
                ) : null}
              </div>
              <h3>{project.name}</h3>
              <p>{project.description}</p>
              <ul class="tag-list" aria-label="Technologies and topics">
                {project.tags.map((tag) => <li class="tag">{tag}</li>)}
              </ul>
              <div class="action-links">
                <a class="rule-link" href={project.href} target="_blank" rel="noopener noreferrer">
                  GitHub
                  <span class="sr-only"> (opens in a new tab)</span>
                  <svg aria-hidden="true" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M5 19 19 5m0 0H8m11 0v11"></path>
                  </svg>
                </a>
                {project.secondaryHref ? (
                  <a class="text-link" href={project.secondaryHref} target="_blank" rel="noopener noreferrer">
                    {project.secondaryLabel}<span class="sr-only"> (opens in a new tab)</span>
                  </a>
                ) : null}
              </div>
            </article>
          ))}
        </div>
      </section>

      <aside class="github-cta reveal" aria-label="More projects on GitHub">
        <p class="section-label">Complete archive</p>
        <p>More repositories, contributions, and experiments live on GitHub.</p>
        <a class="rule-link" href="https://github.com/akshitkrnagpal" target="_blank" rel="noopener noreferrer">
          View more on GitHub
          <span class="sr-only"> (opens in a new tab)</span>
          <svg aria-hidden="true" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M5 19 19 5m0 0H8m11 0v11"></path>
          </svg>
        </a>
      </aside>
    </main>

    <footer class="site-footer">
      <p class="footer-copy">Akshit Kr Nagpal / Project index</p>
      <nav class="footer-links" aria-label="Footer navigation">
        <a href="/">Index</a>
        <a href="/projects" aria-current="page">Projects</a>
        <a href="https://github.com/akshitkrnagpal" target="_blank" rel="noopener noreferrer">GitHub</a>
      </nav>
    </footer>
  </div>
</Layout>

<style>
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .projects-hero {
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    gap: 1rem;
    align-items: end;
    padding-block: clamp(4.5rem, 10vw, 10rem) clamp(5rem, 11vw, 11rem);
  }

  .projects-heading {
    grid-column: span 8;
  }

  .projects-heading .eyebrow {
    margin: 0 0 clamp(2.5rem, 5vw, 5rem);
  }

  .projects-intro {
    grid-column: 9 / -1;
    max-width: 28rem;
    margin: 0 0 0.5rem;
    color: var(--muted);
    font-size: clamp(1rem, 1.35vw, 1.18rem);
    line-height: 1.75;
  }

  .projects-section {
    border-top: 1px solid var(--line-strong);
  }

  .section-masthead {
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    gap: 1rem;
    align-items: baseline;
    padding-block: 1rem clamp(3rem, 6vw, 6rem);
  }

  .section-masthead p,
  .section-masthead h2 {
    margin: 0;
  }

  .section-masthead h2 {
    grid-column: 4 / span 6;
    font-family: var(--font-display);
    font-size: clamp(2.4rem, 4.5vw, 4.5rem);
    font-weight: 400;
    letter-spacing: -0.035em;
    line-height: 1;
  }

  .section-masthead > p:last-child {
    grid-column: 11 / -1;
    color: var(--muted);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-align: right;
    text-transform: uppercase;
  }

  .project-ledger {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .project-ledger > li {
    border-top: 1px solid var(--line);
  }

  .project-row {
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    gap: 1rem;
    padding-block: clamp(2rem, 4.5vw, 4.5rem);
  }

  .project-number {
    grid-column: span 2;
  }

  .project-mark {
    display: grid;
    width: clamp(3.75rem, 5vw, 4.75rem);
    aspect-ratio: 1;
    place-items: center;
    margin-top: 2rem;
    border: 1px solid var(--line);
    overflow: hidden;
  }

  .project-mark img,
  .project-mark svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .project-mark span {
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 1.75rem;
    font-weight: 600;
  }

  .project-identity {
    grid-column: span 3;
  }

  .project-eyebrow {
    margin: 0 0 0.6rem;
    color: var(--muted);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .project-identity h3,
  .small-project h3 {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 400;
    letter-spacing: -0.035em;
    line-height: 1;
  }

  .project-identity h3 {
    font-size: clamp(2.5rem, 4.5vw, 4.75rem);
  }

  .project-labels {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    margin-top: 1.4rem;
  }

  .project-label {
    border: 1px solid var(--line);
    padding: 0.35rem 0.45rem;
  }

  .project-detail {
    grid-column: 6 / span 4;
  }

  .project-description {
    max-width: 34rem;
    margin: 0;
    color: var(--muted);
    font-size: clamp(1rem, 1.25vw, 1.15rem);
    line-height: 1.7;
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem 0.8rem;
    margin: 1.65rem 0 0;
    padding: 0;
    list-style: none;
  }

  .tag {
    color: var(--muted);
  }

  .tag::before {
    color: var(--signal);
    content: "/ ";
  }

  .project-actions {
    grid-column: 11 / -1;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    justify-content: space-between;
    gap: 2rem;
  }

  .star-count {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    color: var(--muted);
    font-size: 0.75rem;
    font-variant-numeric: tabular-nums;
  }

  .star-count svg {
    width: 0.78rem;
    height: 0.78rem;
  }

  .action-links {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem;
  }

  .project-actions .action-links {
    justify-content: flex-end;
  }

  .text-link {
    color: var(--muted);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-underline-offset: 0.3rem;
    text-transform: uppercase;
  }

  .text-link:hover {
    color: var(--signal);
  }

  .smaller-section {
    margin-top: clamp(6rem, 12vw, 12rem);
  }

  .smaller-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    border-top: 1px solid var(--line);
    border-left: 1px solid var(--line);
  }

  .small-project {
    display: flex;
    min-height: 27rem;
    flex-direction: column;
    border-right: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    padding: clamp(1.5rem, 3vw, 3rem);
  }

  .small-project-heading {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .small-project h3 {
    margin-top: clamp(3rem, 7vw, 7rem);
    font-size: clamp(2.6rem, 5vw, 5rem);
  }

  .small-project > p {
    max-width: 34rem;
    margin: 1.4rem 0 0;
    color: var(--muted);
    line-height: 1.7;
  }

  .small-project .tag-list {
    margin-bottom: 2rem;
  }

  .small-project .action-links {
    margin-top: auto;
  }

  .github-cta {
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    gap: 1rem;
    align-items: end;
    margin-top: clamp(6rem, 12vw, 12rem);
    border-top: 1px solid var(--line-strong);
    padding-top: 1rem;
  }

  .github-cta p {
    margin: 0;
  }

  .github-cta > p:nth-child(2) {
    grid-column: 4 / span 5;
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 4vw, 4rem);
    letter-spacing: -0.03em;
    line-height: 1.05;
  }

  .github-cta .rule-link {
    grid-column: 10 / -1;
    width: fit-content;
    justify-self: end;
  }

  @media (max-width: 64rem) {
    .projects-heading {
      grid-column: span 7;
    }

    .projects-intro {
      grid-column: 8 / -1;
    }

    .project-number {
      grid-column: span 1;
    }

    .project-mark {
      display: none;
    }

    .project-identity {
      grid-column: 2 / span 4;
    }

    .project-detail {
      grid-column: 6 / span 5;
    }

    .project-actions {
      grid-column: 11 / -1;
    }
  }

  @media (max-width: 48rem) {
    .projects-hero {
      grid-template-columns: 1fr;
      padding-block: 4rem 6rem;
    }

    .projects-heading,
    .projects-intro {
      grid-column: 1;
    }

    .projects-intro {
      margin-top: 2.5rem;
    }

    .section-masthead {
      grid-template-columns: repeat(6, minmax(0, 1fr));
      padding-bottom: 3rem;
    }

    .section-masthead h2 {
      grid-column: 1 / span 5;
      grid-row: 2;
      margin-top: 1.5rem;
    }

    .section-masthead > p:last-child {
      grid-column: 6;
      grid-row: 1;
    }

    .project-row {
      grid-template-columns: repeat(6, minmax(0, 1fr));
      padding-block: 2.75rem;
    }

    .project-number {
      grid-column: 1;
    }

    .project-identity {
      grid-column: 2 / -1;
    }

    .project-detail {
      grid-column: 2 / -1;
      margin-top: 1rem;
    }

    .project-actions {
      grid-column: 2 / -1;
      align-items: flex-start;
      margin-top: 1rem;
    }

    .project-actions .action-links {
      justify-content: flex-start;
    }

    .smaller-grid {
      grid-template-columns: 1fr;
    }

    .small-project {
      min-height: 24rem;
    }

    .github-cta {
      grid-template-columns: 1fr;
    }

    .github-cta > p:nth-child(2),
    .github-cta .rule-link {
      grid-column: 1;
    }

    .github-cta > p:nth-child(2) {
      margin-top: 3rem;
    }

    .github-cta .rule-link {
      justify-self: start;
      margin-top: 2rem;
    }
  }
</style>
