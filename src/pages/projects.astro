---
import Layout from "../layouts/Layout.astro";

const githubRepositories = [
  "akshitkrnagpal/typesensekit",
  "offerkit/offerkit",
  "akshitkrnagpal/edgepush",
  "akshitkrnagpal/revcat",
  "open-placeholder/open-placeholder",
  "akshitkrnagpal/secret-desk",
  "akshitkrnagpal/env-doctor",
] as const;

const githubHeaders: Record<string, string> = {
  Accept: "application/vnd.github+json",
  "X-GitHub-Api-Version": "2022-11-28",
};

if (import.meta.env.GITHUB_TOKEN) {
  githubHeaders.Authorization = `Bearer ${import.meta.env.GITHUB_TOKEN}`;
}

const githubStars = Object.fromEntries(
  await Promise.all(
    githubRepositories.map(async (repository) => {
      try {
        const response = await fetch(`https://api.github.com/repos/${repository}`, {
          headers: githubHeaders,
        });

        if (!response.ok) {
          console.warn(`Could not fetch GitHub stars for ${repository}: ${response.status}`);
          return [repository, null] as const;
        }

        const data = (await response.json()) as { stargazers_count: number };
        return [repository, data.stargazers_count] as const;
      } catch (error) {
        console.warn(`Could not fetch GitHub stars for ${repository}`, error);
        return [repository, null] as const;
      }
    }),
  ),
) as Record<string, number | null>;

const featuredProjects = [
  {
    name: "TypesenseKit",
    eyebrow: "Typesense CLI & MCP server",
    description:
      "95 typed Typesense operations for humans and AI agents—one CLI and MCP server, read-only by default.",
    tags: ["Typesense", "CLI", "MCP", "95 Operations"],
    labels: ["Active", "Open Source"],
    image: "https://typesensekit.vercel.app/images/typesensekit-robot-favicon-180.png",
    repo: "akshitkrnagpal/typesensekit",
    links: [
      { label: "Docs", href: "https://typesensekit.vercel.app", primary: true },
      { label: "GitHub", href: "https://github.com/akshitkrnagpal/typesensekit" },
    ],
  },
  {
    name: "PromptLens",
    eyebrow: "Autonomous AI reliability",
    description:
      "An autonomous reliability engineer for production LLM systems. Continuously evaluate behavior, catch regressions, investigate failures, and make confident release decisions.",
    tags: ["AI Reliability", "Continuous Evals", "Release Decisions"],
    labels: ["Active", "Early access"],
    image: "https://www.promptlens.io/icon-512.png",
    repo: null,
    links: [{ label: "Visit", href: "https://www.promptlens.io", primary: true }],
  },
  {
    name: "OfferKit",
    eyebrow: "Self-hostable promotion engine",
    description:
      "Agent-first promotion engine for coupons, loyalty, gift cards, referrals, and customer segments. Built for teams that need pricing and promo logic they can own.",
    tags: ["Commerce", "Promotions", "MCP"],
    labels: ["Active", "Open Source", "Self-hostable"],
    icon: "text",
    iconBg: "#111111",
    iconText: "%",
    iconColor: "#F5F0E8",
    repo: "offerkit/offerkit",
    links: [{ label: "GitHub", href: "https://github.com/offerkit/offerkit", primary: true }],
  },
  {
    name: "EdgePush",
    eyebrow: "Open-source push notifications",
    description:
      "Push notifications for iOS and Android on Cloudflare Workers. BYO APNs and FCM credentials, encrypted at rest. Free hosted tier or self-host on your own account.",
    tags: ["Push Notifications", "Cloudflare Workers", "AGPL-3.0"],
    labels: ["Open Source", "Self-hostable"],
    icon: "dot",
    iconBg: "#000000",
    iconText: "",
    iconColor: "#FF6B1A",
    repo: "akshitkrnagpal/edgepush",
    links: [
      { label: "Visit", href: "https://edgepush.dev", primary: true },
      { label: "GitHub", href: "https://github.com/akshitkrnagpal/edgepush" },
    ],
  },
  {
    name: "HookBell",
    eyebrow: "Instant webhook push notifications",
    description:
      "Never miss a webhook again. Get human-readable push notifications on your phone when webhooks fire from services like Stripe, Clerk, Supabase, and more.",
    tags: ["Webhooks", "Developer Tools", "Mobile"],
    labels: ["Production"],
    image: "https://hookbell.com/icon-512.png",
    repo: null,
    links: [{ label: "Visit", href: "https://hookbell.com", primary: true }],
  },
];

const featured = featuredProjects.map((project) => ({
  ...project,
  stars: project.repo ? githubStars[project.repo] : null,
}));

const smallerProjects = [
  {
    name: "revcat",
    description:
      "RevenueCat CLI with full v2 API coverage, OAuth login, and per-repo project context for agents and sandboxes.",
    tags: ["Go", "CLI", "RevenueCat"],
    repo: "akshitkrnagpal/revcat",
    href: "https://github.com/akshitkrnagpal/revcat",
    secondaryHref: "https://revcat.vercel.app",
    secondaryLabel: "Docs",
  },
  {
    name: "open-placeholder",
    description:
      "Self-hosted placeholder image generator. Generate custom placeholder images on the fly.",
    tags: ["Images", "Self-hosted"],
    repo: "open-placeholder/open-placeholder",
    href: "https://github.com/open-placeholder/open-placeholder",
  },
  {
    name: "secret-desk",
    description:
      "Vercel-like editing experience for Kubernetes secrets. Manage secrets with a clean, intuitive interface.",
    tags: ["Kubernetes", "DevOps"],
    repo: "akshitkrnagpal/secret-desk",
    href: "https://github.com/akshitkrnagpal/secret-desk",
  },
  {
    name: "env-doctor",
    description:
      "The .env file auditor every developer needs. Validate, lint, and catch issues in your environment files.",
    tags: ["CLI", "Developer Tools"],
    repo: "akshitkrnagpal/env-doctor",
    href: "https://github.com/akshitkrnagpal/env-doctor",
  },
];

const smaller = smallerProjects.map((project) => ({
  ...project,
  stars: githubStars[project.repo],
}));
---

<Layout
  title="Projects – Akshit Kr Nagpal"
  description="Indie products, open-source tools, and focused experiments built by software engineer Akshit Kr Nagpal."
>
  <div class="shell">
    <header class="site-header">
      <a class="site-id" href="/" aria-label="Akshit Kr Nagpal, home">
        akshit.io <span>/ portfolio</span>
      </a>
      <nav class="site-nav" aria-label="Primary navigation">
        <a href="/">Index</a>
        <a href="/projects" aria-current="page">Projects</a>
      </nav>
    </header>

    <div class="status-strip" aria-label="Page status">
      <span>route <strong>/projects</strong></span>
      <span>records <strong>{featured.length + smaller.length}</strong></span>
      <span>source <strong>github + web</strong></span>
      <span class="ok">● catalog loaded</span>
    </div>

    <main id="main-content" class="projects-main">
      <header class="projects-header reveal">
        <div>
          <p class="section-kicker">Project registry / 001</p>
          <h1>Selected<br />systems</h1>
        </div>
        <div class="header-copy">
          <p>
            Indie products, open-source tools, and smaller experiments. The featured few below get real maintenance; the rest are focused single-purpose utilities.
          </p>
          <dl>
            <div><dt>Featured</dt><dd>{String(featured.length).padStart(2, "0")}</dd></div>
            <div><dt>Utilities</dt><dd>{String(smaller.length).padStart(2, "0")}</dd></div>
            <div><dt>Status</dt><dd class="ready">READY</dd></div>
          </dl>
        </div>
      </header>

      <section class="registry-section reveal reveal-delay-1" aria-labelledby="featured-title">
        <div class="registry-heading">
          <div>
            <span>01</span>
            <h2 id="featured-title">Featured builds</h2>
          </div>
          <p>Maintained products and open-source systems</p>
        </div>

        <div class="featured-list">
          {featured.map((project, index) => (
            <article class="project-row">
              <div class="project-index" aria-hidden="true">{String(index + 1).padStart(2, "0")}</div>
              <div class="project-mark" style={`--mark-bg: ${project.iconBg || "#11191d"}`}>
                {project.image ? (
                  <img
                    src={project.image}
                    alt=""
                    width="80"
                    height="80"
                    loading="lazy"
                    decoding="async"
                  />
                ) : project.icon === "dot" ? (
                  <svg viewBox="0 0 64 64" aria-hidden="true">
                    <circle cx="32" cy="32" r="14" fill={project.iconColor} />
                  </svg>
                ) : (
                  <span style={`color: ${project.iconColor}`}>{project.iconText}</span>
                )}
              </div>

              <div class="project-content">
                <div class="project-title-line">
                  <div>
                    <p>{project.eyebrow}</p>
                    <h3>{project.name}</h3>
                  </div>
                  {project.stars !== null ? (
                    <span class="star-count" aria-label={`${project.stars} GitHub stars`}>
                      <svg viewBox="0 0 16 16" aria-hidden="true"><path d="M8 .25a.75.75 0 0 1 .673.418l1.882 3.815 4.21.612a.75.75 0 0 1 .416 1.279l-3.046 2.97.719 4.192a.75.75 0 0 1-1.088.791L8 12.347l-3.766 1.98a.75.75 0 0 1-1.088-.79l.72-4.194L.818 6.374a.75.75 0 0 1 .416-1.28l4.21-.611L7.327.668A.75.75 0 0 1 8 .25z" /></svg>
                      {project.stars}
                    </span>
                  ) : null}
                </div>
                <p class="project-description">{project.description}</p>
                <div class="project-meta">
                  <div class="tag-list">
                    {project.tags.map((tag) => <span class="tag">{tag}</span>)}
                  </div>
                  <div class="label-list" aria-label="Project status">
                    {project.labels.map((label) => <span>{label}</span>)}
                  </div>
                </div>
              </div>

              <div class="project-actions">
                {project.links.map((link) => (
                  <a
                    class:list={["action-link", { primary: link.primary }]}
                    href={link.href}
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    {link.label}
                    <span class="sr-only"> (opens in a new tab)</span>
                  </a>
                ))}
              </div>
            </article>
          ))}
        </div>
      </section>

      <section class="registry-section utilities-section reveal reveal-delay-2" aria-labelledby="utilities-title">
        <div class="registry-heading">
          <div>
            <span>02</span>
            <h2 id="utilities-title">Tools &amp; experiments</h2>
          </div>
          <p>Focused, single-purpose utilities</p>
        </div>

        <div class="utility-grid">
          {smaller.map((project, index) => (
            <article class="utility-card">
              <div class="utility-topline">
                <span>UTIL_{String(index + 1).padStart(2, "0")}</span>
                {project.stars !== null ? (
                  <span class="star-count" aria-label={`${project.stars} GitHub stars`}>
                    <svg viewBox="0 0 16 16" aria-hidden="true"><path d="M8 .25a.75.75 0 0 1 .673.418l1.882 3.815 4.21.612a.75.75 0 0 1 .416 1.279l-3.046 2.97.719 4.192a.75.75 0 0 1-1.088.791L8 12.347l-3.766 1.98a.75.75 0 0 1-1.088-.79l.72-4.194L.818 6.374a.75.75 0 0 1 .416-1.28l4.21-.611L7.327.668A.75.75 0 0 1 8 .25z" /></svg>
                    {project.stars}
                  </span>
                ) : null}
              </div>
              <h3>{project.name}</h3>
              <p>{project.description}</p>
              <div class="tag-list">
                {project.tags.map((tag) => <span class="tag">{tag}</span>)}
              </div>
              <div class="utility-actions">
                <a class="action-link" href={project.href} target="_blank" rel="noopener noreferrer">
                  GitHub
                  <span class="sr-only"> (opens in a new tab)</span>
                </a>
                {project.secondaryHref ? (
                  <a class="action-link" href={project.secondaryHref} target="_blank" rel="noopener noreferrer">
                    {project.secondaryLabel}
                    <span class="sr-only"> (opens in a new tab)</span>
                  </a>
                ) : null}
              </div>
            </article>
          ))}
        </div>
      </section>

      <div class="github-cta reveal reveal-delay-3">
        <div>
          <span>END_OF_REGISTRY</span>
          <p>More repositories and ongoing work live on GitHub.</p>
        </div>
        <a class="action-link primary" href="https://github.com/akshitkrnagpal" target="_blank" rel="noopener noreferrer">
          View more on GitHub
          <span class="sr-only"> (opens in a new tab)</span>
        </a>
      </div>
    </main>

    <footer class="site-footer">
      <span>akshit.io <strong>— project registry</strong></span>
      <span>EOF / PROJECTS</span>
    </footer>
  </div>
</Layout>

<style>
  .projects-main {
    padding: clamp(1rem, 3vw, 2.5rem);
  }

  .projects-header {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(20rem, 0.9fr);
    border: 1px solid var(--line);
  }

  .projects-header > div {
    padding: clamp(1.75rem, 4.5vw, 4.25rem);
  }

  .projects-header > div:first-child {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    min-height: 25rem;
    border-right: 1px solid var(--line);
    background:
      linear-gradient(90deg, transparent 49.8%, rgba(149, 163, 165, 0.05) 50%, transparent 50.2%),
      linear-gradient(transparent 49.8%, rgba(149, 163, 165, 0.05) 50%, transparent 50.2%);
  }

  h1 {
    margin: 2rem 0 0;
    font-family: var(--font-mono);
    font-size: clamp(3.3rem, 7vw, 7rem);
    font-weight: 700;
    letter-spacing: -0.085em;
    line-height: 0.85;
    text-transform: uppercase;
  }

  .header-copy {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  .header-copy > p {
    margin: 0;
    color: var(--muted);
    font-size: clamp(1rem, 1.5vw, 1.15rem);
    line-height: 1.8;
  }

  .header-copy dl {
    margin: 2rem 0 0;
    border: 1px solid var(--line);
  }

  .header-copy dl div {
    display: grid;
    grid-template-columns: 1fr auto;
    border-bottom: 1px solid var(--line);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
  }

  .header-copy dl div:last-child {
    border-bottom: 0;
  }

  .header-copy dt,
  .header-copy dd {
    margin: 0;
    padding: 0.75rem;
  }

  .header-copy dt {
    color: var(--dim);
  }

  .header-copy dd {
    min-width: 4.5rem;
    border-left: 1px solid var(--line);
    color: var(--muted);
    text-align: right;
  }

  .header-copy dd.ready {
    color: var(--accent);
  }

  .registry-section {
    margin-top: clamp(2rem, 5vw, 4.5rem);
  }

  .registry-heading {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: end;
    gap: 1.5rem;
    margin-bottom: 1rem;
  }

  .registry-heading > div {
    display: flex;
    align-items: baseline;
    gap: 1rem;
  }

  .registry-heading span,
  .utility-topline > span:first-child,
  .github-cta span {
    color: var(--accent);
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.09em;
  }

  h2 {
    margin: 0;
    font-family: var(--font-mono);
    font-size: clamp(1.2rem, 2vw, 1.7rem);
    letter-spacing: -0.035em;
    text-transform: uppercase;
  }

  .registry-heading > p {
    margin: 0;
    color: var(--dim);
    font-family: var(--font-mono);
    font-size: 0.64rem;
    letter-spacing: 0.04em;
    text-align: right;
    text-transform: uppercase;
  }

  .featured-list {
    border: 1px solid var(--line);
  }

  .project-row {
    display: grid;
    grid-template-columns: 3.5rem 5.5rem minmax(0, 1fr) minmax(8.5rem, auto);
    min-height: 17rem;
    border-bottom: 1px solid var(--line);
    background: rgba(13, 19, 22, 0.55);
    transition: background-color 180ms ease;
  }

  .project-row:last-child {
    border-bottom: 0;
  }

  .project-row:hover {
    background: rgba(17, 25, 29, 0.9);
  }

  .project-index {
    display: flex;
    align-items: flex-start;
    justify-content: center;
    border-right: 1px solid var(--line);
    padding-top: 1.3rem;
    color: var(--dim);
    font-family: var(--font-mono);
    font-size: 0.6rem;
  }

  .project-mark {
    width: 3.5rem;
    height: 3.5rem;
    align-self: start;
    margin: 1.3rem 1rem;
    overflow: hidden;
    border: 1px solid var(--line-strong);
    background: var(--mark-bg);
  }

  .project-mark img,
  .project-mark svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .project-mark span {
    display: grid;
    width: 100%;
    height: 100%;
    place-items: center;
    font-family: var(--font-mono);
    font-size: 1.45rem;
    font-weight: 700;
  }

  .project-content {
    min-width: 0;
    border-left: 1px solid var(--line);
    padding: 1.3rem clamp(1.25rem, 3vw, 2.25rem);
  }

  .project-title-line {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
  }

  .project-title-line p {
    margin: 0 0 0.3rem;
    color: var(--dim);
    font-family: var(--font-mono);
    font-size: 0.64rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  h3 {
    margin: 0;
    font-family: var(--font-mono);
    font-size: clamp(1.45rem, 2.5vw, 2.15rem);
    letter-spacing: -0.045em;
  }

  .star-count {
    display: inline-flex;
    flex: none;
    align-items: center;
    gap: 0.35rem;
    color: var(--warning);
    font-family: var(--font-mono);
    font-size: 0.66rem;
  }

  .star-count svg {
    width: 0.75rem;
    height: 0.75rem;
    fill: currentColor;
  }

  .project-description {
    max-width: 49rem;
    margin: 1.25rem 0 1.5rem;
    color: var(--muted);
    line-height: 1.7;
  }

  .project-meta {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1rem;
  }

  .label-list {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 0.5rem;
  }

  .label-list span {
    color: var(--accent);
    font-family: var(--font-mono);
    font-size: 0.58rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .label-list span::before {
    content: "[";
  }

  .label-list span::after {
    content: "]";
  }

  .project-actions {
    display: flex;
    width: 10.5rem;
    flex-direction: column;
    justify-content: flex-end;
    gap: 0.55rem;
    border-left: 1px solid var(--line);
    padding: 1.3rem;
  }

  .project-actions .action-link {
    width: 100%;
  }

  .utility-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    border: 1px solid var(--line);
  }

  .utility-card {
    display: flex;
    min-height: 22rem;
    flex-direction: column;
    border-right: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    padding: clamp(1.25rem, 3vw, 2rem);
    background: rgba(13, 19, 22, 0.55);
    transition: background-color 180ms ease;
  }

  .utility-card:nth-child(2n) {
    border-right: 0;
  }

  .utility-card:nth-last-child(-n + 2) {
    border-bottom: 0;
  }

  .utility-card:hover {
    background: rgba(17, 25, 29, 0.9);
  }

  .utility-topline {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .utility-card h3 {
    font-size: clamp(1.3rem, 2vw, 1.8rem);
  }

  .utility-card > p {
    flex: 1;
    margin: 1rem 0 1.5rem;
    color: var(--muted);
    line-height: 1.7;
  }

  .utility-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    margin-top: 1.5rem;
  }

  .github-cta {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: 2rem;
    margin-top: clamp(2rem, 5vw, 4.5rem);
    border: 1px solid var(--line);
    padding: clamp(1.25rem, 3vw, 2rem);
    background: rgba(125, 249, 194, 0.035);
  }

  .github-cta p {
    margin: 0.4rem 0 0;
    color: var(--muted);
  }

  @media (max-width: 900px) {
    .projects-header {
      grid-template-columns: 1fr 0.8fr;
    }

    .projects-header > div:first-child {
      min-height: 22rem;
    }

    .project-row {
      grid-template-columns: 3rem 4.75rem minmax(0, 1fr);
    }

    .project-mark {
      width: 3rem;
      height: 3rem;
      margin-inline: 0.85rem;
    }

    .project-actions {
      grid-column: 2 / -1;
      width: auto;
      flex-direction: row;
      justify-content: flex-start;
      border-top: 1px solid var(--line);
      border-left: 1px solid var(--line);
    }

    .project-actions .action-link {
      width: auto;
    }
  }

  @media (max-width: 720px) {
    .projects-main {
      padding: 1rem;
    }

    .projects-header {
      grid-template-columns: 1fr;
    }

    .projects-header > div:first-child {
      min-height: 20rem;
      border-right: 0;
      border-bottom: 1px solid var(--line);
    }

    .projects-header > div {
      padding: 1.5rem;
    }

    h1 {
      font-size: clamp(3rem, 16vw, 5rem);
    }

    .registry-heading {
      grid-template-columns: 1fr;
      gap: 0.3rem;
    }

    .registry-heading > p {
      text-align: left;
    }

    .project-row {
      grid-template-columns: 2.75rem 1fr;
    }

    .project-index {
      grid-row: 1 / 4;
    }

    .project-mark {
      grid-column: 2;
      width: 3.5rem;
      height: 3.5rem;
      margin: 1.2rem;
    }

    .project-content {
      grid-column: 2;
      border-top: 1px solid var(--line);
      border-left: 0;
      padding: 1.2rem;
    }

    .project-meta {
      align-items: flex-start;
      flex-direction: column;
    }

    .label-list {
      justify-content: flex-start;
    }

    .project-actions {
      grid-column: 2;
      border-left: 0;
      padding: 1.2rem;
    }

    .utility-grid {
      grid-template-columns: 1fr;
