---
import Layout from "../../layouts/Layout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Layout title={`${post.data.title} – Akshit Kr Nagpal`} description={post.data.description}>
  <main id="main-content" class="min-h-dvh relative overflow-hidden">
    <div
      class="absolute inset-0 opacity-[0.015] pointer-events-none"
      style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%270 0 256 256%27 xmlns=%27http://www.w3.org/2000/svg%27%3E%3Cfilter id=%27noise%27%3E%3CfeTurbulence type=%27fractalNoise%27 baseFrequency=%270.8%27 numOctaves=%274%27 stitchTiles=%27stitch%27/%3E%3C/filter%3E%3Crect width=%27100%25%27 height=%27100%25%27 filter=%27url(%23noise)%27/%3E%3C/svg%3E');"
    ></div>
    <div
      class="absolute top-1/4 -right-32 w-[50vw] h-[50vw] max-w-[700px] max-h-[700px] rounded-full opacity-[0.02]"
      style="background: radial-gradient(circle, var(--color-accent) 0%, transparent 70%);"
    ></div>

    <div class="relative z-10 min-h-dvh flex flex-col">
      <nav class="w-full px-6 md:px-12 lg:px-20 py-6 flex justify-between items-center animate-fade-in">
        <a
          href="/blog"
          class="text-sm tracking-wide font-medium transition-colors duration-300 hover:opacity-70 flex items-center gap-2"
          style="color: var(--color-ink);"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
          </svg>
          Blog
        </a>
        <button
          onclick="if(window.__cmdPalette)window.__cmdPalette.open()"
          class="text-sm tracking-wide font-medium px-4 py-2 border border-[var(--color-ink)]/10 transition-all duration-300 hover:border-[var(--color-ink)]/30 hover:bg-[var(--color-ink)]/[0.03] flex items-center gap-2.5 cursor-pointer"
          style="color: var(--color-ink);"
          aria-label="Open navigation"
        >
          Explore
          <kbd class="hidden sm:inline-flex items-center gap-0.5 text-[10px] tracking-normal font-normal px-1.5 py-0.5 border border-[var(--color-ink)]/10 rounded" style="color: var(--color-muted); font-family: var(--font-body);">
            <span>&#8984;</span>K
          </kbd>
        </button>
      </nav>

      <div class="flex-1 px-6 md:px-12 lg:px-20 py-12 md:py-20">
        <article class="max-w-3xl mx-auto">
          <header class="mb-12 md:mb-16">
            <time
              class="text-xs tracking-[0.3em] uppercase mb-4 block animate-fade-up"
              style="color: var(--color-muted);"
              datetime={post.data.date.toISOString()}
            >
              {post.data.date.toLocaleDateString("en-US", {
                year: "numeric",
                month: "long",
                day: "numeric",
              })}
            </time>
            <h1
              class="text-3xl md:text-4xl lg:text-5xl mb-6 leading-[1.15] animate-fade-up delay-1"
              style="font-family: var(--font-display);"
            >
              {post.data.title}
            </h1>
            <div class="w-16 h-px bg-[var(--color-ink)]/20 mb-6 animate-fade-up delay-2"></div>
            <div class="flex flex-wrap gap-2 animate-fade-up delay-2">
              {post.data.tags.map((tag) => (
                <span
                  class="text-xs tracking-wide px-2.5 py-1 border border-[var(--color-ink)]/10"
                  style="color: var(--color-muted);"
                >
                  {tag}
                </span>
              ))}
            </div>
          </header>

          <div class="prose animate-fade-up delay-3">
            <Content />
          </div>
        </article>
      </div>

      <div class="w-full h-1 bg-[var(--color-accent)] animate-fade-in delay-6"></div>
    </div>
  </main>
</Layout>

<style>
  .prose {
    color: var(--color-ink);
    line-height: 1.8;
    font-size: 1.0625rem;
  }

  .prose :global(h2) {
    font-family: var(--font-display);
    font-size: 1.75rem;
    margin-top: 3rem;
    margin-bottom: 1rem;
    line-height: 1.2;
  }

  .prose :global(h3) {
    font-family: var(--font-display);
    font-size: 1.35rem;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    line-height: 1.3;
  }

  .prose :global(p) {
    margin-bottom: 1.25rem;
    color: var(--color-muted);
  }

  .prose :global(strong) {
    color: var(--color-ink);
    font-weight: 600;
  }

  .prose :global(a) {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: opacity 0.2s;
  }

  .prose :global(a:hover) {
    opacity: 0.7;
  }

  .prose :global(ul),
  .prose :global(ol) {
    margin-bottom: 1.25rem;
    padding-left: 1.5rem;
    color: var(--color-muted);
  }

  .prose :global(li) {
    margin-bottom: 0.5rem;
  }

  .prose :global(code) {
    font-size: 0.875em;
    background: rgba(255, 255, 255, 0.06);
    padding: 0.15em 0.4em;
    border-radius: 4px;
    color: var(--color-ink);
  }

  .prose :global(pre) {
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 6px;
    padding: 1.25rem 1.5rem;
    margin-bottom: 1.5rem;
    overflow-x: auto;
    font-size: 0.875rem;
    line-height: 1.7;
  }

  .prose :global(pre code) {
    background: none;
    padding: 0;
    border-radius: 0;
    font-size: inherit;
  }

  .prose :global(blockquote) {
    border-left: 3px solid var(--color-accent);
    padding-left: 1.25rem;
    margin-bottom: 1.5rem;
    font-style: italic;
    color: var(--color-muted);
  }

  .prose :global(hr) {
    border: none;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    margin: 2.5rem 0;
  }
</style>
