---
interface Props {
  current: "home" | "projects";
}

const { current } = Astro.props;
---

<header class="site-header">
  <div class="frame site-header__inner">
    <a class="site-brand" href="/" aria-label="Akshit Kr Nagpal — home">
      <span class="brand-mark" aria-hidden="true">AK</span>
      <span>akshit</span>
      <span class="brand-path">/ portfolio</span>
    </a>
    <nav class="site-nav" aria-label="Primary navigation">
      <a href="/" aria-current={current === "home" ? "page" : undefined}>
        <span class="site-nav__index">01</span>
        Index
      </a>
      <a href="/projects" aria-current={current === "projects" ? "page" : undefined}>
        <span class="site-nav__index">02</span>
        Projects
      </a>
    </nav>
  </div>
</header>
