---
const pathname = Astro.url.pathname.replace(/\/+$/, "") || "/";
---

<header class="site-header">
  <a class="wordmark" href="/" aria-label="Akshit Kr Nagpal, home">
    <span class="wordmark__monogram" aria-hidden="true">AK</span>
    <span class="wordmark__label">Independent<br />software studio</span>
  </a>

  <nav class="site-nav" aria-label="Primary navigation">
    <a href="/" aria-current={pathname === "/" ? "page" : undefined}>Index</a>
    <a href="/projects" aria-current={pathname === "/projects" ? "page" : undefined}>Projects</a>
  </nav>
</header>
